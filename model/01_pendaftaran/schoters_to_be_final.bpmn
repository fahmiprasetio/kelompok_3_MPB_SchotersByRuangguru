<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Schoters_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_TB">
    <bpmn:participant id="Participant_TB" name="Schoters by Ruangguru - Study Abroad Enrollment (To-Be / Digital + Blockchain)" processRef="Process_Schoters_TB" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Schoters_TB" name="Schoters Enrollment Process (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_TB">
      <bpmn:lane id="L_Student" name="Prospective Student">
        <bpmn:flowNodeRef>Start_Req</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_UploadDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Revise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ReviewOffer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Proceed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_SignDigital</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bnd_Sign</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Consultant" name="Education Consultant">
        <bpmn:flowNodeRef>T_VerifyLead</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Consult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_PrepProgram</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Declined</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_System" name="System &amp; Blockchain Verification">
        <bpmn:flowNodeRef>T_AutoLog</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_HashDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_VerifyHash</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Eligibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Rejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_SendOffer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_GenInvoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RecordPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_GenAgreement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Remind</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_SLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyEnrolled</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Finance" name="Program Team &amp; Finance">
        <bpmn:flowNodeRef>T_ConfirmPay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Onboarding</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Enrolled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Req" name="Submit Enrollment Application" camunda:formRef="form_pendaftaran" camunda:formRefBinding="latest">
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_AutoLog" name="Auto-Log Application in CRM" camunda:expression="${true}">
      <bpmn:dataOutputAssociation id="dout_T_AutoLog_D_LeadRecord"><bpmn:targetRef>D_LeadRecord</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_VerifyLead" name="Verify &amp; Qualify Lead" camunda:candidateGroups="konsultan" />
    <bpmn:userTask id="T_Consult" name="Conduct Online Consultation" camunda:candidateGroups="konsultan">
      <bpmn:dataOutputAssociation id="dout_T_Consult_D_ConsultNotes"><bpmn:targetRef>D_ConsultNotes</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_UploadDocs" name="Upload Supporting Documents" camunda:formRef="form_verifikasi" camunda:formRefBinding="latest" camunda:candidateGroups="mahasiswa">
      <bpmn:dataOutputAssociation id="dout_T_UploadDocs_D_Documents"><bpmn:targetRef>D_Documents</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_HashDocs" name="Hash &amp; Register Documents on Blockchain" camunda:expression="${true}">
      <bpmn:property id="Prop_din_D_Documents_T_HashDocs" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_Documents_T_HashDocs"><bpmn:sourceRef>D_Documents</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_Documents_T_HashDocs</bpmn:targetRef></bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_HashDocs_D_DocHash"><bpmn:targetRef>D_DocHash</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_VerifyHash" name="Verify Document Hash On-Chain" camunda:expression="${true}">
      <bpmn:property id="Prop_din_D_DocHash_T_VerifyHash" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_DocHash_T_VerifyHash"><bpmn:sourceRef>D_DocHash</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_DocHash_T_VerifyHash</bpmn:targetRef></bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_VerifyHash_D_VerifResult"><bpmn:targetRef>D_VerifResult</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="T_Eligibility" name="Evaluate Eligibility (DMN)" camunda:decisionRef="Decision_Kelayakan" camunda:mapDecisionResult="singleResult" camunda:resultVariable="eligibility">
      <bpmn:property id="Prop_din_D_VerifResult_T_Eligibility" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_VerifResult_T_Eligibility"><bpmn:sourceRef>D_VerifResult</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_VerifResult_T_Eligibility</bpmn:targetRef></bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_Eligibility_D_Decision"><bpmn:targetRef>D_Decision</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_Eligibility" name="Eligibility Decision?" default="s12" />
    <bpmn:userTask id="T_Revise" name="Revise &amp; Resubmit Application Data" camunda:candidateGroups="mahasiswa" />
    <bpmn:endEvent id="End_Rejected" name="Application Rejected" />
    <bpmn:userTask id="T_PrepProgram" name="Prepare Program Recommendation" camunda:candidateGroups="konsultan">
      <bpmn:property id="Prop_din_D_ConsultNotes_T_PrepProgram" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_ConsultNotes_T_PrepProgram"><bpmn:sourceRef>D_ConsultNotes</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_ConsultNotes_T_PrepProgram</bpmn:targetRef></bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_PrepProgram_D_OfferLetter"><bpmn:targetRef>D_OfferLetter</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_SendOffer" name="Auto-Send Digital Offer Letter" camunda:expression="${true}">
      <bpmn:property id="Prop_din_D_OfferLetter_T_SendOffer" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_OfferLetter_T_SendOffer"><bpmn:sourceRef>D_OfferLetter</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_OfferLetter_T_SendOffer</bpmn:targetRef></bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_ReviewOffer" name="Review Digital Offer Letter" camunda:formRef="form_review_penawaran" camunda:formRefBinding="latest" camunda:candidateGroups="mahasiswa">
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Proceed" name="Proceed with Enrollment?" default="s17" />
    <bpmn:endEvent id="End_Declined" name="Enrollment Declined" />
    <bpmn:serviceTask id="T_GenInvoice" name="Auto-Generate Invoice" camunda:expression="${true}">
      <bpmn:dataOutputAssociation id="dout_T_GenInvoice_D_Invoice"><bpmn:targetRef>D_Invoice</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_Pay" name="Complete Online Payment" camunda:candidateGroups="mahasiswa">
      <bpmn:property id="Prop_din_D_Invoice_T_Pay" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_Invoice_T_Pay"><bpmn:sourceRef>D_Invoice</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_Invoice_T_Pay</bpmn:targetRef></bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_Pay_D_PaymentData"><bpmn:targetRef>D_PaymentData</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_RecordPayment" name="Record Payment on Blockchain" camunda:expression="${true}">
      <bpmn:property id="Prop_din_D_PaymentData_T_RecordPayment" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_PaymentData_T_RecordPayment"><bpmn:sourceRef>D_PaymentData</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_PaymentData_T_RecordPayment</bpmn:targetRef></bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_RecordPayment_D_PaymentChain"><bpmn:targetRef>D_PaymentChain</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_ConfirmPay" name="Confirm Payment Settlement" camunda:candidateGroups="finance">
      <bpmn:property id="Prop_din_D_PaymentChain_T_ConfirmPay" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_PaymentChain_T_ConfirmPay"><bpmn:sourceRef>D_PaymentChain</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_PaymentChain_T_ConfirmPay</bpmn:targetRef></bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_GenAgreement" name="Auto-Generate Digital Agreement" camunda:expression="${true}">
      <bpmn:dataOutputAssociation id="dout_T_GenAgreement_D_Agreement"><bpmn:targetRef>D_Agreement</bpmn:targetRef></bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_SignDigital" name="Sign Digital Agreement (e-Signature)" camunda:formRef="form_tanda_tangan" camunda:formRefBinding="latest" camunda:candidateGroups="mahasiswa">
      <bpmn:property id="Prop_din_D_Agreement_T_SignDigital" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="din_D_Agreement_T_SignDigital"><bpmn:sourceRef>D_Agreement</bpmn:sourceRef><bpmn:targetRef>Prop_din_D_Agreement_T_SignDigital</bpmn:targetRef></bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_Sign" name="3 Days Elapsed" attachedToRef="T_SignDigital" cancelActivity="false">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="T_Remind" name="Send Signing Reminder">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:connectorId>http-connector</camunda:connectorId>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">https://REPLACE-WITH-YOUR-WEBHOOK-URL</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">{"content":"Pengingat: dokumen perjanjian digital Anda belum ditandatangani. Mohon segera tandatangani."}</camunda:inputParameter>
            <camunda:outputParameter name="remindStatus">${statusCode}</camunda:outputParameter>
          </camunda:inputOutput>
        </camunda:connector>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_SLA" name="Signing SLA Escalated" />
    <bpmn:callActivity id="T_Onboarding" name="Run Student Onboarding" calledElement="Process_Onboarding_Sub" />
    <bpmn:serviceTask id="T_NotifyEnrolled" name="Send Enrollment Confirmation Notifications">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:connectorId>http-connector</camunda:connectorId>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">https://REPLACE-WITH-YOUR-WEBHOOK-URL</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">{"content":"Selamat! Pendaftaran telah selesai dan mahasiswa resmi enrolled di Schoters."}</camunda:inputParameter>
            <camunda:outputParameter name="notifyStatus">${statusCode}</camunda:outputParameter>
          </camunda:inputOutput>
        </camunda:connector>
      </bpmn:extensionElements>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Enrolled" name="Student Successfully Enrolled" />
    <bpmn:dataObjectReference id="D_LeadRecord" name="Lead Record" dataObjectRef="DO_D_LeadRecord" />
    <bpmn:dataObject id="DO_D_LeadRecord" />
    <bpmn:dataObjectReference id="D_ConsultNotes" name="Consultation Notes" dataObjectRef="DO_D_ConsultNotes" />
    <bpmn:dataObject id="DO_D_ConsultNotes" />
    <bpmn:dataObjectReference id="D_Documents" name="Supporting Documents" dataObjectRef="DO_D_Documents" />
    <bpmn:dataObject id="DO_D_Documents" />
    <bpmn:dataObjectReference id="D_DocHash" name="Document Hash (On-Chain)" dataObjectRef="DO_D_DocHash" />
    <bpmn:dataObject id="DO_D_DocHash" />
    <bpmn:dataObjectReference id="D_VerifResult" name="Verification Result" dataObjectRef="DO_D_VerifResult" />
    <bpmn:dataObject id="DO_D_VerifResult" />
    <bpmn:dataObjectReference id="D_Decision" name="Eligibility Result" dataObjectRef="DO_D_Decision" />
    <bpmn:dataObject id="DO_D_Decision" />
    <bpmn:dataObjectReference id="D_OfferLetter" name="Digital Offer Letter" dataObjectRef="DO_D_OfferLetter" />
    <bpmn:dataObject id="DO_D_OfferLetter" />
    <bpmn:dataObjectReference id="D_Invoice" name="Invoice" dataObjectRef="DO_D_Invoice" />
    <bpmn:dataObject id="DO_D_Invoice" />
    <bpmn:dataObjectReference id="D_PaymentData" name="Payment Data" dataObjectRef="DO_D_PaymentData" />
    <bpmn:dataObject id="DO_D_PaymentData" />
    <bpmn:dataObjectReference id="D_PaymentChain" name="Payment Record (On-Chain)" dataObjectRef="DO_D_PaymentChain" />
    <bpmn:dataObject id="DO_D_PaymentChain" />
    <bpmn:dataObjectReference id="D_Agreement" name="Digital Agreement" dataObjectRef="DO_D_Agreement" />
    <bpmn:dataObject id="DO_D_Agreement" />
    <bpmn:sequenceFlow id="s1" sourceRef="Start_Req" targetRef="T_AutoLog" />
    <bpmn:sequenceFlow id="s2" sourceRef="T_AutoLog" targetRef="T_VerifyLead" />
    <bpmn:sequenceFlow id="s3" sourceRef="T_VerifyLead" targetRef="T_Consult" />
    <bpmn:sequenceFlow id="s4" sourceRef="T_Consult" targetRef="T_UploadDocs" />
    <bpmn:sequenceFlow id="s5" sourceRef="T_UploadDocs" targetRef="T_HashDocs" />
    <bpmn:sequenceFlow id="s6" sourceRef="T_HashDocs" targetRef="T_VerifyHash" />
    <bpmn:sequenceFlow id="s7" sourceRef="T_VerifyHash" targetRef="T_Eligibility" />
    <bpmn:sequenceFlow id="s8" sourceRef="T_Eligibility" targetRef="GW_Eligibility" />
    <bpmn:sequenceFlow id="s9" sourceRef="GW_Eligibility" targetRef="T_Revise" name="Revision">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${eligibility.decision==&quot;Revision&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s10" sourceRef="T_Revise" targetRef="T_UploadDocs" />
    <bpmn:sequenceFlow id="s11" sourceRef="GW_Eligibility" targetRef="End_Rejected" name="Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${eligibility.decision==&quot;Rejected&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s12" sourceRef="GW_Eligibility" targetRef="T_PrepProgram" name="Approved" />
    <bpmn:sequenceFlow id="s13" sourceRef="T_PrepProgram" targetRef="T_SendOffer" />
    <bpmn:sequenceFlow id="s14" sourceRef="T_SendOffer" targetRef="T_ReviewOffer" />
    <bpmn:sequenceFlow id="s15" sourceRef="T_ReviewOffer" targetRef="GW_Proceed" />
    <bpmn:sequenceFlow id="s16" sourceRef="GW_Proceed" targetRef="End_Declined" name="Declined">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${offerAccepted==false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="s17" sourceRef="GW_Proceed" targetRef="T_GenInvoice" name="Proceed" />
    <bpmn:sequenceFlow id="s18" sourceRef="T_GenInvoice" targetRef="T_Pay" />
    <bpmn:sequenceFlow id="s19" sourceRef="T_Pay" targetRef="T_RecordPayment" />
    <bpmn:sequenceFlow id="s20" sourceRef="T_RecordPayment" targetRef="T_ConfirmPay" />
    <bpmn:sequenceFlow id="s21" sourceRef="T_ConfirmPay" targetRef="T_GenAgreement" />
    <bpmn:sequenceFlow id="s22" sourceRef="T_GenAgreement" targetRef="T_SignDigital" />
    <bpmn:sequenceFlow id="s23" sourceRef="T_SignDigital" targetRef="T_Onboarding" />
    <bpmn:sequenceFlow id="s24" sourceRef="Bnd_Sign" targetRef="T_Remind" />
    <bpmn:sequenceFlow id="s25" sourceRef="T_Remind" targetRef="End_SLA" />
    <bpmn:sequenceFlow id="s26" sourceRef="T_Onboarding" targetRef="T_NotifyEnrolled" />
    <bpmn:sequenceFlow id="s27" sourceRef="T_NotifyEnrolled" targetRef="End_Enrolled" />
  </bpmn:process>
  <bpmn:process id="Process_Onboarding_Sub" name="Student Onboarding" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="OB_Start" name="Onboarding Started" />
    <bpmn:userTask id="OB_Video" name="Schedule Onboarding Video Call" camunda:candidateGroups="program" />
    <bpmn:serviceTask id="OB_LMS" name="Provision LMS Access" camunda:expression="${true}" />
    <bpmn:serviceTask id="OB_Welcome" name="Send Welcome Kit" camunda:expression="${true}" />
    <bpmn:endEvent id="OB_End" name="Onboarding Completed" />
    <bpmn:sequenceFlow id="ob1" sourceRef="OB_Start" targetRef="OB_Video" />
    <bpmn:sequenceFlow id="ob2" sourceRef="OB_Video" targetRef="OB_LMS" />
    <bpmn:sequenceFlow id="ob3" sourceRef="OB_LMS" targetRef="OB_Welcome" />
    <bpmn:sequenceFlow id="ob4" sourceRef="OB_Welcome" targetRef="OB_End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_TB">
    <bpmndi:BPMNPlane id="Plane_TB" bpmnElement="Collab_TB">
      <bpmndi:BPMNShape id="di_Participant_TB" bpmnElement="Participant_TB" isHorizontal="true"><dc:Bounds x="140" y="80" width="4748" height="960" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Student" bpmnElement="L_Student" isHorizontal="true"><dc:Bounds x="170" y="80" width="4718" height="240" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Consultant" bpmnElement="L_Consultant" isHorizontal="true"><dc:Bounds x="170" y="320" width="4718" height="240" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_System" bpmnElement="L_System" isHorizontal="true"><dc:Bounds x="170" y="560" width="4718" height="240" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Finance" bpmnElement="L_Finance" isHorizontal="true"><dc:Bounds x="170" y="800" width="4718" height="240" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Start_Req" bpmnElement="Start_Req"><dc:Bounds x="252" y="182" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_AutoLog" bpmnElement="T_AutoLog"><dc:Bounds x="415" y="640" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_VerifyLead" bpmnElement="T_VerifyLead"><dc:Bounds x="620" y="400" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Consult" bpmnElement="T_Consult"><dc:Bounds x="825" y="400" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_UploadDocs" bpmnElement="T_UploadDocs"><dc:Bounds x="1030" y="160" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_HashDocs" bpmnElement="T_HashDocs"><dc:Bounds x="1235" y="640" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_VerifyHash" bpmnElement="T_VerifyHash"><dc:Bounds x="1440" y="640" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Eligibility" bpmnElement="T_Eligibility"><dc:Bounds x="1645" y="640" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Eligibility" bpmnElement="GW_Eligibility"><dc:Bounds x="1885" y="655" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Revise" bpmnElement="T_Revise"><dc:Bounds x="1850" y="160" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_End_Rejected" bpmnElement="End_Rejected"><dc:Bounds x="2097" y="662" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_PrepProgram" bpmnElement="T_PrepProgram"><dc:Bounds x="2055" y="400" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_SendOffer" bpmnElement="T_SendOffer"><dc:Bounds x="2260" y="640" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ReviewOffer" bpmnElement="T_ReviewOffer"><dc:Bounds x="2465" y="160" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Proceed" bpmnElement="GW_Proceed"><dc:Bounds x="2705" y="175" width="50" height="50" /></bpmndi:BPMNShape>
