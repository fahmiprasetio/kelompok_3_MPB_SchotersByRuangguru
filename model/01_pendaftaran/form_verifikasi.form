      "layout": { "row": "Row_intro", "columns": null },
      "id": "Field_intro_ver"
    },
    {
      "label": "Documents Complete",
      "type": "checkbox",
      "layout": { "row": "Row_documentsComplete", "columns": null },
      "id": "Field_documentsComplete",
      "key": "documentsComplete"
    },
    {
      "label": "Risk Level",
      "type": "select",
      "layout": { "row": "Row_riskLevel", "columns": null },
      "id": "Field_riskLevel",
