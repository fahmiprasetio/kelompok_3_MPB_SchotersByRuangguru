<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Process_Visa_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Process_Visa_TB">
    <bpmn:participant id="Part_Process_Visa_TB" name="Schoters by Ruangguru - Pengajuan Visa Pelajar (To-Be / Terdigitalisasi)" processRef="Process_Visa_TB" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Visa_TB" name="Pengajuan Visa Pelajar (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_Visa_TB">
      <bpmn:lane id="L_Student" name="Calon Mahasiswa">
        <bpmn:flowNodeRef>Start_Visa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Compile</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_CompleteDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ResubmitFin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Interview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Officer" name="Visa Counselor">
        <bpmn:flowNodeRef>T_Validate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_TrackVisa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Denied</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_System" name="Sistem Schoters">
        <bpmn:flowNodeRef>T_EvalVisa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Visa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_SubmitVisa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_VisaRes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyVisa</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Granted</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Visa" name="Ajukan Permohonan Visa" camunda:formRef="form_visa_request" camunda:formRefBinding="latest"><bpmn:outgoing>v1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="T_Compile" name="Susun Dokumen Visa"><bpmn:incoming>v1</bpmn:incoming><bpmn:outgoing>v2</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_Validate" name="Validasi Dokumen &amp; Bukti Finansial" camunda:formRef="form_visa_check" camunda:formRefBinding="latest"><bpmn:incoming>v2</bpmn:incoming><bpmn:incoming>v6</bpmn:incoming><bpmn:incoming>v8</bpmn:incoming><bpmn:outgoing>v3</bpmn:outgoing></bpmn:userTask>
    <bpmn:businessRuleTask id="T_EvalVisa" name="Evaluasi Jalur Visa (DMN)" camunda:decisionRef="Decision_Visa" camunda:mapDecisionResult="singleEntry" camunda:resultVariable="visaDecision"><bpmn:incoming>v3</bpmn:incoming><bpmn:outgoing>v4</bpmn:outgoing></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_Visa" name="Jalur Visa?" default="f_v_submit"><bpmn:incoming>v4</bpmn:incoming><bpmn:outgoing>v5</bpmn:outgoing><bpmn:outgoing>v7</bpmn:outgoing><bpmn:outgoing>v9</bpmn:outgoing><bpmn:outgoing>f_v_submit</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_CompleteDocs" name="Lengkapi Dokumen Kurang"><bpmn:incoming>v5</bpmn:incoming><bpmn:outgoing>v6</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_ResubmitFin" name="Kirim Ulang Bukti Finansial"><bpmn:incoming>v7</bpmn:incoming><bpmn:outgoing>v8</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_Interview" name="Hadiri Wawancara Visa"><bpmn:incoming>v9</bpmn:incoming><bpmn:outgoing>v10</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="T_SubmitVisa" name="Submit Aplikasi Visa ke Kedutaan" camunda:expression="${true}"><bpmn:incoming>v10</bpmn:incoming><bpmn:incoming>f_v_submit</bpmn:incoming><bpmn:outgoing>v11</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="T_TrackVisa" name="Lacak Keputusan Visa" camunda:formRef="form_visa_result" camunda:formRefBinding="latest"><bpmn:incoming>v11</bpmn:incoming><bpmn:outgoing>v12</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_VisaRes" name="Hasil Visa?" default="f_denied"><bpmn:incoming>v12</bpmn:incoming><bpmn:outgoing>v13</bpmn:outgoing><bpmn:outgoing>f_denied</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_NotifyVisa" name="Beri Tahu Hasil Visa" camunda:expression="${true}"><bpmn:incoming>v13</bpmn:incoming><bpmn:outgoing>v14</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_Granted" name="Visa Disetujui"><bpmn:incoming>v14</bpmn:incoming></bpmn:endEvent>
    <bpmn:endEvent id="End_Denied" name="Visa Ditolak"><bpmn:incoming>f_denied</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="v1" sourceRef="Start_Visa" targetRef="T_Compile" />
    <bpmn:sequenceFlow id="v2" sourceRef="T_Compile" targetRef="T_Validate" />
    <bpmn:sequenceFlow id="v3" sourceRef="T_Validate" targetRef="T_EvalVisa" />
    <bpmn:sequenceFlow id="v4" sourceRef="T_EvalVisa" targetRef="GW_Visa" />
    <bpmn:sequenceFlow id="v5" sourceRef="GW_Visa" targetRef="T_CompleteDocs" name="Lengkapi Dokumen">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${visaDecision==&quot;Complete Documents&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="v6" sourceRef="T_CompleteDocs" targetRef="T_Validate" />
    <bpmn:sequenceFlow id="v7" sourceRef="GW_Visa" targetRef="T_ResubmitFin" name="Bukti Finansial">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${visaDecision==&quot;Resubmit Financial Proof&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="v8" sourceRef="T_ResubmitFin" targetRef="T_Validate" />
    <bpmn:sequenceFlow id="v9" sourceRef="GW_Visa" targetRef="T_Interview" name="Wawancara">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${visaDecision==&quot;Schedule Interview&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="v10" sourceRef="T_Interview" targetRef="T_SubmitVisa" />
    <bpmn:sequenceFlow id="f_v_submit" sourceRef="GW_Visa" targetRef="T_SubmitVisa" name="Submit" />
    <bpmn:sequenceFlow id="v11" sourceRef="T_SubmitVisa" targetRef="T_TrackVisa" />
    <bpmn:sequenceFlow id="v12" sourceRef="T_TrackVisa" targetRef="GW_VisaRes" />
    <bpmn:sequenceFlow id="v13" sourceRef="GW_VisaRes" targetRef="T_NotifyVisa" name="Disetujui">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${visaResult==&quot;Granted&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="v14" sourceRef="T_NotifyVisa" targetRef="End_Granted" />
    <bpmn:sequenceFlow id="f_denied" sourceRef="GW_VisaRes" targetRef="End_Denied" name="Ditolak" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_Process_Visa_TB">
    <bpmndi:BPMNPlane id="Plane_Process_Visa_TB" bpmnElement="Collab_Process_Visa_TB">
      <bpmndi:BPMNShape id="di_Part_Process_Visa_TB" bpmnElement="Part_Process_Visa_TB" isHorizontal="true"><dc:Bounds x="160" y="80" width="3120" height="600" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Student" bpmnElement="L_Student" isHorizontal="true"><dc:Bounds x="190" y="80" width="3090" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Officer" bpmnElement="L_Officer" isHorizontal="true"><dc:Bounds x="190" y="280" width="3090" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_System" bpmnElement="L_System" isHorizontal="true"><dc:Bounds x="190" y="480" width="3090" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Start_Visa" bpmnElement="Start_Visa"><dc:Bounds x="342" y="162" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Compile" bpmnElement="T_Compile"><dc:Bounds x="520" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Validate" bpmnElement="T_Validate"><dc:Bounds x="740" y="340" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_EvalVisa" bpmnElement="T_EvalVisa"><dc:Bounds x="960" y="540" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Visa" bpmnElement="GW_Visa"><dc:Bounds x="1215" y="555" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_CompleteDocs" bpmnElement="T_CompleteDocs"><dc:Bounds x="1400" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ResubmitFin" bpmnElement="T_ResubmitFin"><dc:Bounds x="1620" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Interview" bpmnElement="T_Interview"><dc:Bounds x="1840" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_SubmitVisa" bpmnElement="T_SubmitVisa"><dc:Bounds x="2060" y="540" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_TrackVisa" bpmnElement="T_TrackVisa"><dc:Bounds x="2280" y="340" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_VisaRes" bpmnElement="GW_VisaRes"><dc:Bounds x="2535" y="555" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_NotifyVisa" bpmnElement="T_NotifyVisa"><dc:Bounds x="2720" y="540" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_End_Granted" bpmnElement="End_Granted"><dc:Bounds x="2982" y="562" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_End_Denied" bpmnElement="End_Denied"><dc:Bounds x="2762" y="362" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="di_v1" bpmnElement="v1"><di:waypoint x="378" y="180" /><di:waypoint x="520" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v2" bpmnElement="v2"><di:waypoint x="640" y="180" /><di:waypoint x="690" y="180" /><di:waypoint x="690" y="380" /><di:waypoint x="740" y="380" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v3" bpmnElement="v3"><di:waypoint x="860" y="380" /><di:waypoint x="910" y="380" /><di:waypoint x="910" y="580" /><di:waypoint x="960" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v4" bpmnElement="v4"><di:waypoint x="1080" y="580" /><di:waypoint x="1215" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v5" bpmnElement="v5"><di:waypoint x="1265" y="580" /><di:waypoint x="1332" y="580" /><di:waypoint x="1332" y="180" /><di:waypoint x="1400" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v6" bpmnElement="v6"><di:waypoint x="1460" y="140" /><di:waypoint x="1460" y="100" /><di:waypoint x="800" y="100" /><di:waypoint x="800" y="340" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v7" bpmnElement="v7"><di:waypoint x="1265" y="580" /><di:waypoint x="1442" y="580" /><di:waypoint x="1442" y="180" /><di:waypoint x="1620" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v8" bpmnElement="v8"><di:waypoint x="1680" y="140" /><di:waypoint x="1680" y="100" /><di:waypoint x="800" y="100" /><di:waypoint x="800" y="340" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v9" bpmnElement="v9"><di:waypoint x="1265" y="580" /><di:waypoint x="1552" y="580" /><di:waypoint x="1552" y="180" /><di:waypoint x="1840" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v10" bpmnElement="v10"><di:waypoint x="1960" y="180" /><di:waypoint x="2010" y="180" /><di:waypoint x="2010" y="580" /><di:waypoint x="2060" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_v_submit" bpmnElement="f_v_submit"><di:waypoint x="1265" y="580" /><di:waypoint x="2060" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v11" bpmnElement="v11"><di:waypoint x="2180" y="580" /><di:waypoint x="2230" y="580" /><di:waypoint x="2230" y="380" /><di:waypoint x="2280" y="380" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v12" bpmnElement="v12"><di:waypoint x="2400" y="380" /><di:waypoint x="2468" y="380" /><di:waypoint x="2468" y="580" /><di:waypoint x="2535" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v13" bpmnElement="v13"><di:waypoint x="2585" y="580" /><di:waypoint x="2720" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_v14" bpmnElement="v14"><di:waypoint x="2840" y="580" /><di:waypoint x="2982" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_denied" bpmnElement="f_denied"><di:waypoint x="2585" y="580" /><di:waypoint x="2674" y="580" /><di:waypoint x="2674" y="380" /><di:waypoint x="2762" y="380" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
