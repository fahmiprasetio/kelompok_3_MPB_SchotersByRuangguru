<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Process_Refund_AS" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Process_Refund_AS">
    <bpmn:participant id="Part_Process_Refund_AS" name="Schoters by Ruangguru - Refund / Pembatalan Program (As-Is / Manual)" processRef="Process_Refund_AS" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Refund_AS" name="Refund / Pembatalan Program (As-Is)" isExecutable="false">
    <bpmn:startEvent id="RAS_Start" name="Mahasiswa Minta Refund (Email)"><bpmn:outgoing>ra1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="RAS_Check" name="Cek Kelayakan Manual"><bpmn:incoming>ra1</bpmn:incoming><bpmn:outgoing>ra2</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="RAS_Discuss" name="Diskusi dgn Finance Manual"><bpmn:incoming>ra2</bpmn:incoming><bpmn:outgoing>ra3</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="RAS_Approve" name="Routing Persetujuan Manual"><bpmn:incoming>ra3</bpmn:incoming><bpmn:outgoing>ra4</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="RAS_Process" name="Proses Refund via Bank Manual"><bpmn:incoming>ra4</bpmn:incoming><bpmn:outgoing>ra5</bpmn:outgoing></bpmn:userTask>
    <bpmn:endEvent id="RAS_End" name="Refund Ditangani (Manual)"><bpmn:incoming>ra5</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="ra1" sourceRef="RAS_Start" targetRef="RAS_Check" />
    <bpmn:sequenceFlow id="ra2" sourceRef="RAS_Check" targetRef="RAS_Discuss" />
    <bpmn:sequenceFlow id="ra3" sourceRef="RAS_Discuss" targetRef="RAS_Approve" />
    <bpmn:sequenceFlow id="ra4" sourceRef="RAS_Approve" targetRef="RAS_Process" />
    <bpmn:sequenceFlow id="ra5" sourceRef="RAS_Process" targetRef="RAS_End" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_Process_Refund_AS">
    <bpmndi:BPMNPlane id="Plane_Process_Refund_AS" bpmnElement="Collab_Process_Refund_AS">
      <bpmndi:BPMNShape id="di_Part_Process_Refund_AS" bpmnElement="Part_Process_Refund_AS" isHorizontal="true"><dc:Bounds x="160" y="80" width="1580" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Start" bpmnElement="RAS_Start"><dc:Bounds x="342" y="162" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Check" bpmnElement="RAS_Check"><dc:Bounds x="520" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Discuss" bpmnElement="RAS_Discuss"><dc:Bounds x="740" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Approve" bpmnElement="RAS_Approve"><dc:Bounds x="960" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Process" bpmnElement="RAS_Process"><dc:Bounds x="1180" y="140" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_End" bpmnElement="RAS_End"><dc:Bounds x="1442" y="162" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="di_ra1" bpmnElement="ra1"><di:waypoint x="378" y="180" /><di:waypoint x="520" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra2" bpmnElement="ra2"><di:waypoint x="640" y="180" /><di:waypoint x="740" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra3" bpmnElement="ra3"><di:waypoint x="860" y="180" /><di:waypoint x="960" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra4" bpmnElement="ra4"><di:waypoint x="1080" y="180" /><di:waypoint x="1180" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra5" bpmnElement="ra5"><di:waypoint x="1300" y="180" /><di:waypoint x="1442" y="180" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
