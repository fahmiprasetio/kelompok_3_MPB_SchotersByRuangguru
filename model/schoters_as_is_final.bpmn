<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Schoters_AS" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collab_AS">
    <bpmn:participant id="Participant_AS" name="Schoters by Ruangguru - Study Abroad Enrollment (As-Is / Manual)" processRef="Process_Schoters_AS"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Schoters_AS" name="Schoters Enrollment Process (As-Is)" isExecutable="false" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_AS">
      <bpmn:lane id="L_Student" name="Prospective Student &amp; Parent">
        <bpmn:flowNodeRef>AS_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Request</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Attend</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Resubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ReviewOffer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Proceed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RecvReceipt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Sign</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Consultant" name="Education Consultant / Sales">
        <bpmn:flowNodeRef>T_LogReq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Schedule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Conduct</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_Timer1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Followup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RecvDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ReviewDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyDocIssue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_PrepOffer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_SendOffer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Drop</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyFinance</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Academic" name="Academic &amp; Mentor Team">
        <bpmn:flowNodeRef>T_CheckAvail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Match</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Onboard</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Finance" name="Admin &amp; Finance">
        <bpmn:flowNodeRef>T_Invoice</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_SendInstr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_Timer2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_VerifyPay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Pay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyPayIssue</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Receipt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_PrepAgreement</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Archive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Enrolled</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="f37" sourceRef="T_Archive" targetRef="End_Enrolled"/>
    <bpmn:sequenceFlow id="f36" sourceRef="T_Onboard" targetRef="T_Archive"/>
    <bpmn:sequenceFlow id="f35" sourceRef="T_Sign" targetRef="T_Onboard"/>
    <bpmn:sequenceFlow id="f34" sourceRef="T_PrepAgreement" targetRef="T_Sign"/>
    <bpmn:sequenceFlow id="f33" sourceRef="T_RecvReceipt" targetRef="T_PrepAgreement"/>
    <bpmn:sequenceFlow id="f32" sourceRef="T_Receipt" targetRef="T_RecvReceipt"/>
    <bpmn:sequenceFlow id="f31" name="Valid" sourceRef="GW_Pay" targetRef="T_Receipt"/>
    <bpmn:sequenceFlow id="f29" name="Invalid" sourceRef="GW_Pay" targetRef="T_NotifyPayIssue"/>
    <bpmn:sequenceFlow id="f28" sourceRef="T_VerifyPay" targetRef="GW_Pay"/>
    <bpmn:sequenceFlow id="f27" sourceRef="T_Pay" targetRef="T_VerifyPay"/>
    <bpmn:sequenceFlow id="f30" sourceRef="T_NotifyPayIssue" targetRef="T_Pay"/>
    <bpmn:sequenceFlow id="f26" sourceRef="AS_Timer2" targetRef="T_Pay"/>
    <bpmn:sequenceFlow id="f25" sourceRef="T_SendInstr" targetRef="AS_Timer2"/>
    <bpmn:sequenceFlow id="f24" sourceRef="T_Invoice" targetRef="T_SendInstr"/>
    <bpmn:sequenceFlow id="f23" sourceRef="T_NotifyFinance" targetRef="T_Invoice"/>
    <bpmn:sequenceFlow id="f22" name="Proceed" sourceRef="GW_Proceed" targetRef="T_NotifyFinance"/>
    <bpmn:sequenceFlow id="f21" name="Not Interested" sourceRef="GW_Proceed" targetRef="End_Drop"/>
    <bpmn:sequenceFlow id="f20" sourceRef="T_ReviewOffer" targetRef="GW_Proceed"/>
    <bpmn:sequenceFlow id="f19" sourceRef="T_SendOffer" targetRef="T_ReviewOffer"/>
    <bpmn:sequenceFlow id="f18" sourceRef="T_PrepOffer" targetRef="T_SendOffer"/>
    <bpmn:sequenceFlow id="f15" sourceRef="T_NotifyDocIssue" targetRef="T_Resubmit"/>
    <bpmn:sequenceFlow id="f17" name="Complete &amp; Valid" sourceRef="GW_Docs" targetRef="T_PrepOffer"/>
    <bpmn:sequenceFlow id="f14" name="Incomplete / Invalid" sourceRef="GW_Docs" targetRef="T_NotifyDocIssue"/>
    <bpmn:sequenceFlow id="f13" sourceRef="T_ReviewDocs" targetRef="GW_Docs"/>
    <bpmn:sequenceFlow id="f12" sourceRef="T_RecvDocs" targetRef="T_ReviewDocs"/>
    <bpmn:sequenceFlow id="f16" sourceRef="T_Resubmit" targetRef="T_RecvDocs"/>
    <bpmn:sequenceFlow id="f11" sourceRef="T_Submit" targetRef="T_RecvDocs"/>
    <bpmn:sequenceFlow id="f10" sourceRef="T_Followup" targetRef="T_Submit"/>
    <bpmn:sequenceFlow id="f9" sourceRef="AS_Timer1" targetRef="T_Followup"/>
    <bpmn:sequenceFlow id="f8" sourceRef="T_Match" targetRef="AS_Timer1"/>
    <bpmn:sequenceFlow id="f7" sourceRef="T_CheckAvail" targetRef="T_Match"/>
    <bpmn:sequenceFlow id="f6" sourceRef="T_Conduct" targetRef="T_CheckAvail"/>
    <bpmn:sequenceFlow id="f5" sourceRef="T_Attend" targetRef="T_Conduct"/>
    <bpmn:sequenceFlow id="f4" sourceRef="T_Schedule" targetRef="T_Attend"/>
    <bpmn:sequenceFlow id="f3" sourceRef="T_LogReq" targetRef="T_Schedule"/>
    <bpmn:sequenceFlow id="f2" sourceRef="T_Request" targetRef="T_LogReq"/>
    <bpmn:sequenceFlow id="f1" sourceRef="AS_Start" targetRef="T_Request"/>
    <bpmn:dataObjectReference id="D_Agreement" name="Enrollment Agreement / LoA" dataObjectRef="DO_D_Agreement"/>
    <bpmn:dataObject id="DO_D_Agreement"/>
    <bpmn:dataObjectReference id="D_Receipt" name="Payment Confirmation Receipt" dataObjectRef="DO_D_Receipt"/>
    <bpmn:dataObject id="DO_D_Receipt"/>
    <bpmn:dataObjectReference id="D_PaymentProof" name="Payment Evidence (Transfer Receipt)" dataObjectRef="DO_D_PaymentProof"/>
    <bpmn:dataObject id="DO_D_PaymentProof"/>
    <bpmn:dataObjectReference id="D_Invoice" name="Manual Invoice" dataObjectRef="DO_D_Invoice"/>
    <bpmn:dataObject id="DO_D_Invoice"/>
    <bpmn:dataObjectReference id="D_OfferLetter" name="Recommendation &amp; Offer Letter" dataObjectRef="DO_D_OfferLetter"/>
    <bpmn:dataObject id="DO_D_OfferLetter"/>
    <bpmn:dataObjectReference id="D_VerificationNote" name="Document Verification Note" dataObjectRef="DO_D_VerificationNote"/>
    <bpmn:dataObject id="DO_D_VerificationNote"/>
    <bpmn:dataObjectReference id="D_Documents" name="Supporting Documents" dataObjectRef="DO_D_Documents"/>
    <bpmn:dataObject id="DO_D_Documents"/>
    <bpmn:dataObjectReference id="D_ProgramAvailability" name="Program &amp; Mentor Availability" dataObjectRef="DO_D_ProgramAvailability"/>
    <bpmn:dataObject id="DO_D_ProgramAvailability"/>
    <bpmn:dataObjectReference id="D_ConsultNotes" name="Consultation Notes" dataObjectRef="DO_D_ConsultNotes"/>
    <bpmn:dataObject id="DO_D_ConsultNotes"/>
    <bpmn:dataObjectReference id="D_LeadRecord" name="Lead Record (CRM Spreadsheet)" dataObjectRef="DO_D_LeadRecord"/>
    <bpmn:dataObject id="DO_D_LeadRecord"/>
    <bpmn:dataObjectReference id="D_ConsultRequest" name="Consultation Request" dataObjectRef="DO_D_ConsultRequest"/>
    <bpmn:dataObject id="DO_D_ConsultRequest"/>
    <bpmn:endEvent id="End_Enrolled" name="Student Officially Enrolled"/>
    <bpmn:userTask id="T_Archive" name="Archive Student File Manually (Drive/Physical)"/>
    <bpmn:userTask id="T_Onboard" name="Initiate Student Onboarding (Video Call + LMS Setup)"/>
    <bpmn:userTask id="T_Sign" name="Sign Enrollment Agreement / LoA">
      <bpmn:property id="Property_08lw3sq" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_Agreement_T_Sign">
        <bpmn:sourceRef>D_Agreement</bpmn:sourceRef>
        <bpmn:targetRef>Property_08lw3sq</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_PrepAgreement" name="Prepare Enrollment Agreement / LoA">
      <bpmn:dataOutputAssociation id="dout_T_PrepAgreement_D_Agreement">
        <bpmn:targetRef>D_Agreement</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_RecvReceipt" name="Receive Payment Confirmation Receipt">
      <bpmn:property id="Property_0a8lt5t" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_Receipt_T_RecvReceipt">
        <bpmn:sourceRef>D_Receipt</bpmn:sourceRef>
        <bpmn:targetRef>Property_0a8lt5t</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Receipt" name="Issue Manual Payment Confirmation Receipt">
      <bpmn:dataOutputAssociation id="dout_T_Receipt_D_Receipt">
        <bpmn:targetRef>D_Receipt</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_NotifyPayIssue" name="Notify Student: Payment Issue (Wrong Amount/Account)"/>
    <bpmn:exclusiveGateway id="GW_Pay" name="Payment Valid?" default="f31"/>
    <bpmn:userTask id="T_VerifyPay" name="Manually Verify Payment Evidence (Check Bank Statement)">
      <bpmn:property id="Property_1blwata" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_PaymentProof_T_VerifyPay">
        <bpmn:sourceRef>D_PaymentProof</bpmn:sourceRef>
        <bpmn:targetRef>Property_1blwata</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Pay" name="Make Manual Bank Transfer Payment">
      <bpmn:property id="Property_057rhe8" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_Invoice_T_Pay">
        <bpmn:sourceRef>D_Invoice</bpmn:sourceRef>
        <bpmn:targetRef>Property_057rhe8</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_Pay_D_PaymentProof">
        <bpmn:targetRef>D_PaymentProof</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="AS_Timer2" name="Await Payment Transfer (3 Days)">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="T_SendInstr" name="Send Bank Transfer Instructions to Student"/>
    <bpmn:userTask id="T_Invoice" name="Issue Manual Invoice / Payment Instructions">
      <bpmn:dataOutputAssociation id="dout_T_Invoice_D_Invoice">
        <bpmn:targetRef>D_Invoice</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_NotifyFinance" name="Notify Finance of Accepted Deal &amp; Expected Payment"/>
    <bpmn:endEvent id="End_Drop" name="Student Drops Out / Not Proceeding"/>
    <bpmn:exclusiveGateway id="GW_Proceed" name="Interested to Proceed?" default="f22"/>
    <bpmn:userTask id="T_ReviewOffer" name="Review Program Recommendation &amp; Offer Letter">
      <bpmn:property id="Property_1xf4mf5" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_OfferLetter_T_ReviewOffer">
        <bpmn:sourceRef>D_OfferLetter</bpmn:sourceRef>
        <bpmn:targetRef>Property_1xf4mf5</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_SendOffer" name="Send Offer Letter to Student"/>
    <bpmn:userTask id="T_PrepOffer" name="Prepare Program Recommendation &amp; Offer Letter (Manual)">
      <bpmn:property id="Property_04pvh2f" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_ConsultNotes_T_PrepOffer">
        <bpmn:sourceRef>D_ConsultNotes</bpmn:sourceRef>
        <bpmn:targetRef>Property_04pvh2f</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataInputAssociation id="din_D_ProgramAvailability_T_PrepOffer">
        <bpmn:sourceRef>D_ProgramAvailability</bpmn:sourceRef>
        <bpmn:targetRef>Property_04pvh2f</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_PrepOffer_D_OfferLetter">
        <bpmn:targetRef>D_OfferLetter</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Resubmit" name="Resubmit Corrected Documents">
      <bpmn:dataOutputAssociation id="dout_T_Resubmit_D_Documents">
        <bpmn:targetRef>D_Documents</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_NotifyDocIssue" name="Notify Student of Document Issue (Missing/Invalid)"/>
    <bpmn:exclusiveGateway id="GW_Docs" name="Documents Complete &amp; Valid?" default="f17"/>
    <bpmn:userTask id="T_ReviewDocs" name="Manually Review Document Authenticity (Visual Check)">
      <bpmn:dataOutputAssociation id="dout_T_ReviewDocs_D_VerificationNote">
        <bpmn:targetRef>D_VerificationNote</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_RecvDocs" name="Receive Student Documents">
      <bpmn:property id="Property_0qg1iy4" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_Documents_T_RecvDocs">
        <bpmn:sourceRef>D_Documents</bpmn:sourceRef>
        <bpmn:targetRef>Property_0qg1iy4</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Submit" name="Submit Supporting Documents via Email/WhatsApp">
      <bpmn:dataOutputAssociation id="dout_T_Submit_D_Documents">
        <bpmn:targetRef>D_Documents</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Followup" name="Manual Follow-up via WhatsApp (3-5 Days)"/>
    <bpmn:intermediateCatchEvent id="AS_Timer1" name="Await Document Submission (3 Days)">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="T_Match" name="Match Student with Suitable Program &amp; Mentor"/>
    <bpmn:userTask id="T_CheckAvail" name="Check Mentor &amp; Program Availability">
      <bpmn:dataOutputAssociation id="dout_T_CheckAvail_D_ProgramAvailability">
        <bpmn:targetRef>D_ProgramAvailability</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Conduct" name="Conduct Consultation (Assess Needs, Goals, Budget)">
      <bpmn:dataOutputAssociation id="dout_T_Conduct_D_ConsultNotes">
        <bpmn:targetRef>D_ConsultNotes</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Attend" name="Attend 1-on-1 Online Consultation"/>
    <bpmn:userTask id="T_Schedule" name="Schedule &amp; Send Consultation Invitation"/>
    <bpmn:userTask id="T_LogReq" name="Receive &amp; Log Consultation Request in CRM (Spreadsheet)">
      <bpmn:property id="Property_1ccwnpy" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="din_D_ConsultRequest_T_LogReq">
        <bpmn:sourceRef>D_ConsultRequest</bpmn:sourceRef>
        <bpmn:targetRef>Property_1ccwnpy</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="dout_T_LogReq_D_LeadRecord">
        <bpmn:targetRef>D_LeadRecord</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_Request" name="Request Free Consultation (via WhatsApp)">
      <bpmn:dataOutputAssociation id="dout_T_Request_D_ConsultRequest">
        <bpmn:targetRef>D_ConsultRequest</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:startEvent id="AS_Start" name="Prospective Student Interested in Study Abroad"/>
    <bpmn:textAnnotation id="TA_VerifyPay">
      <bpmn:text>Manual bank reconciliation: confirmation can take hours or days</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TA_Review">
      <bpmn:text>Manual visual document check: no automated validation, slow &amp; error-prone</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TA_Followup">
      <bpmn:text>Manual follow-up depends on staff memory: leads often go cold</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TA_Log">
      <bpmn:text>Manual CRM logging in a spreadsheet: prone to duplicate or lost leads</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_TA_VerifyPay" associationDirection="None" sourceRef="T_VerifyPay" targetRef="TA_VerifyPay"/>
    <bpmn:association id="assoc_TA_Review" associationDirection="None" sourceRef="T_ReviewDocs" targetRef="TA_Review"/>
    <bpmn:association id="assoc_TA_Followup" associationDirection="None" sourceRef="T_Followup" targetRef="TA_Followup"/>
    <bpmn:association id="assoc_TA_Log" associationDirection="None" sourceRef="T_LogReq" targetRef="TA_Log"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_AS">
    <bpmndi:BPMNPlane id="Plane_AS" bpmnElement="Collab_AS">
      <bpmndi:BPMNShape id="di_Participant_AS" bpmnElement="Participant_AS" isHorizontal="true">
        <dc:Bounds x="140" y="80" width="6858" height="960"/>
