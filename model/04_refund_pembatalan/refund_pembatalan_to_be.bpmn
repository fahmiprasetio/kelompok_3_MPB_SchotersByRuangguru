<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Process_Refund_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Process_Refund_TB">
    <bpmn:participant id="Part_Process_Refund_TB" name="Schoters by Ruangguru - Refund / Pembatalan Program (To-Be / Terdigitalisasi)" processRef="Process_Refund_TB" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Refund_TB" name="Refund / Pembatalan Program (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_Refund_TB">
      <bpmn:lane id="L_Student" name="Mahasiswa">
        <bpmn:flowNodeRef>Start_Refund</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Finance" name="Tim Finance">
        <bpmn:flowNodeRef>T_ReviewReq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ProcessFull</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ApprovePartial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ProcessPartial</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_System" name="Sistem Schoters">
        <bpmn:flowNodeRef>T_EvalRefund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RefundDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RefundReject</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Refund" name="Ajukan Permintaan Refund" camunda:formRef="form_refund_request" camunda:formRefBinding="latest"><bpmn:outgoing>r1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="T_ReviewReq" name="Tinjau Permintaan Refund" camunda:formRef="form_refund_review" camunda:formRefBinding="latest"><bpmn:incoming>r1</bpmn:incoming><bpmn:outgoing>r2</bpmn:outgoing></bpmn:userTask>
    <bpmn:businessRuleTask id="T_EvalRefund" name="Evaluasi Kelayakan Refund (DMN)" camunda:decisionRef="Decision_Refund" camunda:mapDecisionResult="singleEntry" camunda:resultVariable="refundDecision"><bpmn:incoming>r2</bpmn:incoming><bpmn:outgoing>r3</bpmn:outgoing></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_Refund" name="Keputusan Refund?" default="f_norefund"><bpmn:incoming>r3</bpmn:incoming><bpmn:outgoing>r4</bpmn:outgoing><bpmn:outgoing>r6</bpmn:outgoing><bpmn:outgoing>f_norefund</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_ProcessFull" name="Proses Refund Penuh" camunda:expression="${true}"><bpmn:incoming>r4</bpmn:incoming><bpmn:outgoing>r5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="T_ApprovePartial" name="Setujui Refund Sebagian"><bpmn:incoming>r6</bpmn:incoming><bpmn:outgoing>r7</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="T_ProcessPartial" name="Proses Refund Sebagian" camunda:expression="${true}"><bpmn:incoming>r7</bpmn:incoming><bpmn:outgoing>r8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="T_NotifyDone" name="Beri Tahu Refund Selesai" camunda:expression="${true}"><bpmn:incoming>r5</bpmn:incoming><bpmn:incoming>r8</bpmn:incoming><bpmn:outgoing>r9</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_RefundDone" name="Refund Selesai"><bpmn:incoming>r9</bpmn:incoming></bpmn:endEvent>
    <bpmn:serviceTask id="T_NotifyReject" name="Beri Tahu Refund Ditolak" camunda:expression="${true}"><bpmn:incoming>f_norefund</bpmn:incoming><bpmn:outgoing>r10</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_RefundReject" name="Refund Ditolak"><bpmn:incoming>r10</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="r1" sourceRef="Start_Refund" targetRef="T_ReviewReq" />
    <bpmn:sequenceFlow id="r2" sourceRef="T_ReviewReq" targetRef="T_EvalRefund" />
    <bpmn:sequenceFlow id="r3" sourceRef="T_EvalRefund" targetRef="GW_Refund" />
    <bpmn:sequenceFlow id="r4" sourceRef="GW_Refund" targetRef="T_ProcessFull" name="Refund Penuh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${refundDecision==&quot;Full Refund&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="r5" sourceRef="T_ProcessFull" targetRef="T_NotifyDone" />
    <bpmn:sequenceFlow id="r6" sourceRef="GW_Refund" targetRef="T_ApprovePartial" name="Refund Sebagian">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${refundDecision==&quot;Partial Refund&quot;}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="r7" sourceRef="T_ApprovePartial" targetRef="T_ProcessPartial" />
    <bpmn:sequenceFlow id="r8" sourceRef="T_ProcessPartial" targetRef="T_NotifyDone" />
    <bpmn:sequenceFlow id="r9" sourceRef="T_NotifyDone" targetRef="End_RefundDone" />
    <bpmn:sequenceFlow id="f_norefund" sourceRef="GW_Refund" targetRef="T_NotifyReject" name="Tanpa Refund" />
    <bpmn:sequenceFlow id="r10" sourceRef="T_NotifyReject" targetRef="End_RefundReject" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_Process_Refund_TB">
    <bpmndi:BPMNPlane id="Plane_Process_Refund_TB" bpmnElement="Collab_Process_Refund_TB">
      <bpmndi:BPMNShape id="di_Part_Process_Refund_TB" bpmnElement="Part_Process_Refund_TB" isHorizontal="true"><dc:Bounds x="160" y="80" width="2240" height="600" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Student" bpmnElement="L_Student" isHorizontal="true"><dc:Bounds x="190" y="80" width="2210" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Finance" bpmnElement="L_Finance" isHorizontal="true"><dc:Bounds x="190" y="280" width="2210" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_System" bpmnElement="L_System" isHorizontal="true"><dc:Bounds x="190" y="480" width="2210" height="200" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Start_Refund" bpmnElement="Start_Refund"><dc:Bounds x="342" y="162" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ReviewReq" bpmnElement="T_ReviewReq"><dc:Bounds x="520" y="340" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_EvalRefund" bpmnElement="T_EvalRefund"><dc:Bounds x="740" y="540" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Refund" bpmnElement="GW_Refund"><dc:Bounds x="995" y="555" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ProcessFull" bpmnElement="T_ProcessFull"><dc:Bounds x="1180" y="340" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ApprovePartial" bpmnElement="T_ApprovePartial"><dc:Bounds x="1400" y="340" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ProcessPartial" bpmnElement="T_ProcessPartial"><dc:Bounds x="1620" y="340" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_NotifyDone" bpmnElement="T_NotifyDone"><dc:Bounds x="1840" y="540" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_End_RefundDone" bpmnElement="End_RefundDone"><dc:Bounds x="2102" y="562" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_NotifyReject" bpmnElement="T_NotifyReject"><dc:Bounds x="1180" y="540" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_End_RefundReject" bpmnElement="End_RefundReject"><dc:Bounds x="1442" y="562" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="di_r1" bpmnElement="r1"><di:waypoint x="378" y="180" /><di:waypoint x="449" y="180" /><di:waypoint x="449" y="380" /><di:waypoint x="520" y="380" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r2" bpmnElement="r2"><di:waypoint x="640" y="380" /><di:waypoint x="690" y="380" /><di:waypoint x="690" y="580" /><di:waypoint x="740" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r3" bpmnElement="r3"><di:waypoint x="860" y="580" /><di:waypoint x="995" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r4" bpmnElement="r4"><di:waypoint x="1045" y="580" /><di:waypoint x="1112" y="580" /><di:waypoint x="1112" y="380" /><di:waypoint x="1180" y="380" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r5" bpmnElement="r5"><di:waypoint x="1300" y="380" /><di:waypoint x="1570" y="380" /><di:waypoint x="1570" y="580" /><di:waypoint x="1840" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r6" bpmnElement="r6"><di:waypoint x="1045" y="580" /><di:waypoint x="1222" y="580" /><di:waypoint x="1222" y="380" /><di:waypoint x="1400" y="380" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r7" bpmnElement="r7"><di:waypoint x="1520" y="380" /><di:waypoint x="1620" y="380" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r8" bpmnElement="r8"><di:waypoint x="1740" y="380" /><di:waypoint x="1790" y="380" /><di:waypoint x="1790" y="580" /><di:waypoint x="1840" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r9" bpmnElement="r9"><di:waypoint x="1960" y="580" /><di:waypoint x="2102" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_f_norefund" bpmnElement="f_norefund"><di:waypoint x="1045" y="580" /><di:waypoint x="1180" y="580" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_r10" bpmnElement="r10"><di:waypoint x="1300" y="580" /><di:waypoint x="1442" y="580" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
