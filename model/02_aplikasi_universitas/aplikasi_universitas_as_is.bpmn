    <bpmn:dataObject id="DObj_ScanLoA" />
    <bpmn:sequenceFlow id="a1" sourceRef="AS_Start" targetRef="AS_Consult" />
    <bpmn:sequenceFlow id="a2" sourceRef="AS_Consult" targetRef="AS_FillForm" />
    <bpmn:sequenceFlow id="a3" sourceRef="AS_FillForm" targetRef="AS_SendDocs" />
    <bpmn:sequenceFlow id="a4" sourceRef="AS_SendDocs" targetRef="AS_Recap" />
    <bpmn:sequenceFlow id="a5" sourceRef="AS_Recap" targetRef="AS_VerifyDocs" />
    <bpmn:sequenceFlow id="a6" sourceRef="AS_VerifyDocs" targetRef="AS_Review" />
    <bpmn:sequenceFlow id="a7" sourceRef="AS_Review" targetRef="AS_GwCheck" />
    <bpmn:sequenceFlow id="a8" sourceRef="AS_GwCheck" targetRef="AS_ReqRevisi" name="Tidak Lengkap" />
    <bpmn:sequenceFlow id="a9" sourceRef="AS_ReqRevisi" targetRef="AS_FixDocs" />
    <bpmn:sequenceFlow id="a10" sourceRef="AS_FixDocs" targetRef="AS_Review" name="Kirim Ulang" />
    <bpmn:sequenceFlow id="a11" sourceRef="AS_GwCheck" targetRef="AS_Shortlist" name="Lengkap &amp; Layak" />
    <bpmn:sequenceFlow id="a12" sourceRef="AS_Shortlist" targetRef="AS_BuildList" />
    <bpmn:sequenceFlow id="a13" sourceRef="AS_BuildList" targetRef="AS_Approve" />
    <bpmn:sequenceFlow id="a14" sourceRef="AS_Approve" targetRef="AS_GwApprove" />
    <bpmn:sequenceFlow id="a15" sourceRef="AS_GwApprove" targetRef="AS_BuildList" name="Belum Setuju" />
    <bpmn:sequenceFlow id="a16" sourceRef="AS_GwApprove" targetRef="AS_PrepDocs" name="Setuju" />
    <bpmn:sequenceFlow id="a17" sourceRef="AS_PrepDocs" targetRef="AS_SubmitManual" />
    <bpmn:sequenceFlow id="a18" sourceRef="AS_SubmitManual" targetRef="AS_UpdateSheet" />
    <bpmn:sequenceFlow id="a19" sourceRef="AS_UpdateSheet" targetRef="AS_TrackResult" />
    <bpmn:sequenceFlow id="a20" sourceRef="AS_TrackResult" targetRef="AS_GwResult" />
    <bpmn:sequenceFlow id="a21" sourceRef="AS_GwResult" targetRef="AS_RecordLoA" name="Diterima" />
    <bpmn:sequenceFlow id="a22" sourceRef="AS_RecordLoA" targetRef="AS_NotifyOk" />
    <bpmn:sequenceFlow id="a23" sourceRef="AS_NotifyOk" targetRef="AS_EndOk" />
    <bpmn:sequenceFlow id="a24" sourceRef="AS_GwResult" targetRef="AS_NotifyNo" name="Ditolak" />
    <bpmn:sequenceFlow id="a25" sourceRef="AS_NotifyNo" targetRef="AS_EndNo" />
  </bpmn:process>
