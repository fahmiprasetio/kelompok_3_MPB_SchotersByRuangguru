<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Process_AppUniv_AS" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Process_AppUniv_AS">
    <bpmn:participant id="Part_Process_AppUniv_AS" name="Schoters by Ruangguru - Pemrosesan Aplikasi Universitas (As-Is / Manual)" processRef="Process_AppUniv_AS" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AppUniv_AS" name="Pemrosesan Aplikasi Universitas (As-Is)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_AppUniv_AS">
      <bpmn:lane id="L_Student" name="Calon Mahasiswa">
        <bpmn:flowNodeRef>AS_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_FillForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_SendDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_FixDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_Approve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_GwApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_EndOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_EndNo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Mentor" name="Mentor Akademik">
        <bpmn:flowNodeRef>AS_Consult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_GwCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_ReqRevisi</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_Shortlist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_BuildList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_TrackResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_GwResult</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_NotifyOk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_NotifyNo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Admin" name="Tim Operasional Schoters">
        <bpmn:flowNodeRef>AS_Recap</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_VerifyDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_PrepDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_SubmitManual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_UpdateSheet</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AS_RecordLoA</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="AS_Start" name="Mahasiswa Hubungi via WhatsApp / Email"><bpmn:outgoing>a1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="AS_Consult" name="Konsultasi Awal &amp; Pemetaan Minat"><bpmn:incoming>a1</bpmn:incoming><bpmn:outgoing>a2</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_HasilKonsultasi"><bpmn:targetRef>DObjRef_HasilKonsultasi</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_FillForm" name="Isi Google Form Minat Manual"><bpmn:incoming>a2</bpmn:incoming><bpmn:outgoing>a3</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_FormMinat"><bpmn:targetRef>DObjRef_FormMinat</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_SendDocs" name="Kirim Dokumen Akademik via Email"><bpmn:incoming>a3</bpmn:incoming><bpmn:outgoing>a4</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_EmailDocs"><bpmn:targetRef>DObjRef_EmailDocs</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_Recap" name="Rekap Dokumen ke Drive &amp; Spreadsheet"><bpmn:incoming>a4</bpmn:incoming><bpmn:outgoing>a5</bpmn:outgoing><bpmn:property id="Prop_AS_Recap_FormMinat" name="__targetRef_placeholder" /><bpmn:property id="Prop_AS_Recap_EmailDocs" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_FormMinat_AS_Recap"><bpmn:sourceRef>DObjRef_FormMinat</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Recap_FormMinat</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation id="DIn_EmailDocs_AS_Recap"><bpmn:sourceRef>DObjRef_EmailDocs</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Recap_EmailDocs</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_Spreadsheet"><bpmn:targetRef>DObjRef_Spreadsheet</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_VerifyDocs" name="Periksa Kelengkapan Dokumen Manual"><bpmn:incoming>a5</bpmn:incoming><bpmn:outgoing>a6</bpmn:outgoing><bpmn:property id="Prop_AS_VerifyDocs_EmailDocs" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_EmailDocs_AS_VerifyDocs"><bpmn:sourceRef>DObjRef_EmailDocs</bpmn:sourceRef><bpmn:targetRef>Prop_AS_VerifyDocs_EmailDocs</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_ChecklistDok"><bpmn:targetRef>DObjRef_ChecklistDok</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_Review" name="Tinjau Esai &amp; Transkrip Manual"><bpmn:incoming>a6</bpmn:incoming><bpmn:incoming>a10</bpmn:incoming><bpmn:outgoing>a7</bpmn:outgoing><bpmn:property id="Prop_AS_Review_EmailDocs" name="__targetRef_placeholder" /><bpmn:property id="Prop_AS_Review_ChecklistDok" name="__targetRef_placeholder" /><bpmn:property id="Prop_AS_Review_HasilKonsultasi" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_EmailDocs_AS_Review"><bpmn:sourceRef>DObjRef_EmailDocs</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Review_EmailDocs</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation id="DIn_ChecklistDok_AS_Review"><bpmn:sourceRef>DObjRef_ChecklistDok</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Review_ChecklistDok</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation id="DIn_HasilKonsultasi_AS_Review"><bpmn:sourceRef>DObjRef_HasilKonsultasi</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Review_HasilKonsultasi</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_CatatanReview"><bpmn:targetRef>DObjRef_CatatanReview</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:exclusiveGateway id="AS_GwCheck" name="Dokumen Lengkap &amp; Layak?"><bpmn:incoming>a7</bpmn:incoming><bpmn:outgoing>a8</bpmn:outgoing><bpmn:outgoing>a11</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="AS_ReqRevisi" name="Kirim Permintaan Revisi via Email"><bpmn:incoming>a8</bpmn:incoming><bpmn:outgoing>a9</bpmn:outgoing><bpmn:property id="Prop_AS_ReqRevisi_CatatanReview" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_CatatanReview_AS_ReqRevisi"><bpmn:sourceRef>DObjRef_CatatanReview</bpmn:sourceRef><bpmn:targetRef>Prop_AS_ReqRevisi_CatatanReview</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_EmailRevisi"><bpmn:targetRef>DObjRef_EmailRevisi</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_FixDocs" name="Perbaiki &amp; Kirim Ulang Dokumen"><bpmn:incoming>a9</bpmn:incoming><bpmn:outgoing>a10</bpmn:outgoing><bpmn:property id="Prop_AS_FixDocs_EmailRevisi" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_EmailRevisi_AS_FixDocs"><bpmn:sourceRef>DObjRef_EmailRevisi</bpmn:sourceRef><bpmn:targetRef>Prop_AS_FixDocs_EmailRevisi</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_Shortlist" name="Riset &amp; Shortlist Universitas Manual"><bpmn:incoming>a11</bpmn:incoming><bpmn:outgoing>a12</bpmn:outgoing><bpmn:property id="Prop_AS_Shortlist_CatatanReview" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_CatatanReview_AS_Shortlist"><bpmn:sourceRef>DObjRef_CatatanReview</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Shortlist_CatatanReview</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_BuildList" name="Susun Daftar Universitas Manual"><bpmn:incoming>a12</bpmn:incoming><bpmn:incoming>a15</bpmn:incoming><bpmn:outgoing>a13</bpmn:outgoing><bpmn:property id="Prop_AS_BuildList_CatatanReview" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_CatatanReview_AS_BuildList"><bpmn:sourceRef>DObjRef_CatatanReview</bpmn:sourceRef><bpmn:targetRef>Prop_AS_BuildList_CatatanReview</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_DaftarUniv"><bpmn:targetRef>DObjRef_DaftarUniv</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_Approve" name="Setujui Daftar &amp; Isi Form Aplikasi Manual"><bpmn:incoming>a13</bpmn:incoming><bpmn:outgoing>a14</bpmn:outgoing><bpmn:property id="Prop_AS_Approve_DaftarUniv" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DaftarUniv_AS_Approve"><bpmn:sourceRef>DObjRef_DaftarUniv</bpmn:sourceRef><bpmn:targetRef>Prop_AS_Approve_DaftarUniv</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:exclusiveGateway id="AS_GwApprove" name="Mahasiswa Setuju Daftar?"><bpmn:incoming>a14</bpmn:incoming><bpmn:outgoing>a15</bpmn:outgoing><bpmn:outgoing>a16</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="AS_PrepDocs" name="Siapkan Berkas Aplikasi per Universitas"><bpmn:incoming>a16</bpmn:incoming><bpmn:outgoing>a17</bpmn:outgoing><bpmn:property id="Prop_AS_PrepDocs_DaftarUniv" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DaftarUniv_AS_PrepDocs"><bpmn:sourceRef>DObjRef_DaftarUniv</bpmn:sourceRef><bpmn:targetRef>Prop_AS_PrepDocs_DaftarUniv</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_BerkasAplikasi"><bpmn:targetRef>DObjRef_BerkasAplikasi</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_SubmitManual" name="Submit Aplikasi Manual per Universitas"><bpmn:incoming>a17</bpmn:incoming><bpmn:outgoing>a18</bpmn:outgoing><bpmn:property id="Prop_AS_SubmitManual_BerkasAplikasi" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_BerkasAplikasi_AS_SubmitManual"><bpmn:sourceRef>DObjRef_BerkasAplikasi</bpmn:sourceRef><bpmn:targetRef>Prop_AS_SubmitManual_BerkasAplikasi</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_BuktiSubmit"><bpmn:targetRef>DObjRef_BuktiSubmit</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_UpdateSheet" name="Update Status di Spreadsheet"><bpmn:incoming>a18</bpmn:incoming><bpmn:outgoing>a19</bpmn:outgoing><bpmn:property id="Prop_AS_UpdateSheet_BuktiSubmit" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_BuktiSubmit_AS_UpdateSheet"><bpmn:sourceRef>DObjRef_BuktiSubmit</bpmn:sourceRef><bpmn:targetRef>Prop_AS_UpdateSheet_BuktiSubmit</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_StatusSheet"><bpmn:targetRef>DObjRef_StatusSheet</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_TrackResult" name="Lacak Hasil via Email Universitas"><bpmn:incoming>a19</bpmn:incoming><bpmn:outgoing>a20</bpmn:outgoing><bpmn:property id="Prop_AS_TrackResult_Spreadsheet" name="__targetRef_placeholder" /><bpmn:property id="Prop_AS_TrackResult_StatusSheet" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Spreadsheet_AS_TrackResult"><bpmn:sourceRef>DObjRef_Spreadsheet</bpmn:sourceRef><bpmn:targetRef>Prop_AS_TrackResult_Spreadsheet</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation id="DIn_StatusSheet_AS_TrackResult"><bpmn:sourceRef>DObjRef_StatusSheet</bpmn:sourceRef><bpmn:targetRef>Prop_AS_TrackResult_StatusSheet</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_EmailHasil"><bpmn:targetRef>DObjRef_EmailHasil</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:exclusiveGateway id="AS_GwResult" name="Hasil Diterima?"><bpmn:incoming>a20</bpmn:incoming><bpmn:outgoing>a21</bpmn:outgoing><bpmn:outgoing>a24</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="AS_RecordLoA" name="Arsipkan Scan LoA Manual"><bpmn:incoming>a21</bpmn:incoming><bpmn:outgoing>a22</bpmn:outgoing><bpmn:property id="Prop_AS_RecordLoA_EmailHasil" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_EmailHasil_AS_RecordLoA"><bpmn:sourceRef>DObjRef_EmailHasil</bpmn:sourceRef><bpmn:targetRef>Prop_AS_RecordLoA_EmailHasil</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_ScanLoA"><bpmn:targetRef>DObjRef_ScanLoA</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="AS_NotifyOk" name="Beri Tahu Mahasiswa (Diterima) via Email"><bpmn:incoming>a22</bpmn:incoming><bpmn:outgoing>a23</bpmn:outgoing></bpmn:userTask>
    <bpmn:endEvent id="AS_EndOk" name="Aplikasi Diterima (Manual)"><bpmn:incoming>a23</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="AS_NotifyNo" name="Beri Tahu Mahasiswa (Ditolak) via Email"><bpmn:incoming>a24</bpmn:incoming><bpmn:outgoing>a25</bpmn:outgoing><bpmn:property id="Prop_AS_NotifyNo_EmailHasil" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_EmailHasil_AS_NotifyNo"><bpmn:sourceRef>DObjRef_EmailHasil</bpmn:sourceRef><bpmn:targetRef>Prop_AS_NotifyNo_EmailHasil</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:endEvent id="AS_EndNo" name="Aplikasi Tidak Diterima (Manual)"><bpmn:incoming>a25</bpmn:incoming></bpmn:endEvent>
    <bpmn:dataObjectReference id="DObjRef_HasilKonsultasi" name="Hasil Konsultasi (Catatan Manual)" dataObjectRef="DObj_HasilKonsultasi" />
    <bpmn:dataObject id="DObj_HasilKonsultasi" />
    <bpmn:dataObjectReference id="DObjRef_FormMinat" name="Form Minat (Google Form)" dataObjectRef="DObj_FormMinat" />
    <bpmn:dataObject id="DObj_FormMinat" />
    <bpmn:dataObjectReference id="DObjRef_EmailDocs" name="Email Dokumen Akademik" dataObjectRef="DObj_EmailDocs" />
    <bpmn:dataObject id="DObj_EmailDocs" />
    <bpmn:dataObjectReference id="DObjRef_Spreadsheet" name="Spreadsheet Tracking Manual" dataObjectRef="DObj_Spreadsheet" />
    <bpmn:dataObject id="DObj_Spreadsheet" />
