<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Process_AppUniv_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Process_AppUniv_TB">
    <bpmn:participant id="Part_Process_AppUniv_TB" name="Schoters by Ruangguru - Pemrosesan Aplikasi Universitas (To-Be / Terdigitalisasi)" processRef="Process_AppUniv_TB" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AppUniv_TB" name="Pemrosesan Aplikasi Universitas (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_AppUniv_TB">
      <bpmn:lane id="L_Student" name="Calon Mahasiswa">
        <bpmn:flowNodeRef>Start_App</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_CollectDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ReviseDocs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Mentor" name="Academic Mentor">
        <bpmn:flowNodeRef>T_ReviewDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AdjustList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_HandleSubmitEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_SubmitRetry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_SubmitFailed</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Track</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bnd_TrackSLA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_NotAccepted</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_System" name="Sistem Schoters">
        <bpmn:flowNodeRef>T_AutoCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_EvalApp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_App</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifySubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_SubmitAck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RemindAdm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RemindAdm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Adm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RecordLoA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Notify</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_Enroll</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_LoA</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_App" name="Ajukan Permintaan Aplikasi Universitas" camunda:formRef="form_app_request" camunda:formRefBinding="latest"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="T_CollectDocs" name="Kumpulkan Dokumen Akademik"><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_Docs"><bpmn:targetRef>DObjRef_Docs</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:serviceTask id="T_AutoCheck" name="Validasi Kelengkapan Dokumen Otomatis (OCR)"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCE5 [SISTEM] Dokumen aplikasi diterima dan divalidasi otomatis (OCR + cek kelengkapan)."}</camunda:inputParameter><camunda:outputParameter name="logAutoCheck">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing><bpmn:property id="Prop_T_AutoCheck_Docs" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Docs_T_AutoCheck"><bpmn:sourceRef>DObjRef_Docs</bpmn:sourceRef><bpmn:targetRef>Prop_T_AutoCheck_Docs</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_Validation"><bpmn:targetRef>DObjRef_Validation</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:userTask id="T_ReviewDocs" name="Tinjau Kualitas Dokumen dan Esai" camunda:formRef="form_review_docs" camunda:formRefBinding="latest"><bpmn:incoming>f3</bpmn:incoming><bpmn:incoming>f9</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing><bpmn:property id="Prop_T_ReviewDocs_Docs" name="__targetRef_placeholder" /><bpmn:property id="Prop_T_ReviewDocs_Validation" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Docs_T_ReviewDocs"><bpmn:sourceRef>DObjRef_Docs</bpmn:sourceRef><bpmn:targetRef>Prop_T_ReviewDocs_Docs</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation id="DIn_Validation_T_ReviewDocs"><bpmn:sourceRef>DObjRef_Validation</bpmn:sourceRef><bpmn:targetRef>Prop_T_ReviewDocs_Validation</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_Review"><bpmn:targetRef>DObjRef_Review</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:businessRuleTask id="T_EvalApp" name="Evaluasi Kesiapan Aplikasi (DMN)" camunda:decisionRef="Decision_Aplikasi" camunda:mapDecisionResult="singleEntry" camunda:resultVariable="appDecision"><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing><bpmn:property id="Prop_T_EvalApp_Review" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Review_T_EvalApp"><bpmn:sourceRef>DObjRef_Review</bpmn:sourceRef><bpmn:targetRef>Prop_T_EvalApp_Review</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_Decision"><bpmn:targetRef>DObjRef_Decision</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_App" name="Kesiapan Aplikasi?" default="f_submit"><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f6</bpmn:outgoing><bpmn:outgoing>f8</bpmn:outgoing><bpmn:outgoing>f_submit</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ReviseDocs" name="Perbaiki Dokumen Aplikasi"><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_AdjustList" name="Sesuaikan Daftar Universitas Target"><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_UnivList"><bpmn:targetRef>DObjRef_UnivList</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:serviceTask id="T_NotifySubmit" name="Beritahu Mahasiswa: Submit Dimulai"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCE4 [SISTEM] Aplikasi siap dikirim. Memulai proses submit otomatis ke portal universitas."}</camunda:inputParameter><camunda:outputParameter name="logNotifySubmit">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f_submit</bpmn:incoming><bpmn:outgoing>f_ns</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="T_Submit" name="Submit Aplikasi ke Portal Universitas"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83C\uDFDB\uFE0F [SISTEM] Aplikasi telah dikirim otomatis ke portal universitas tujuan."}</camunda:inputParameter><camunda:outputParameter name="logSubmit">${statusCode}</camunda:outputParameter><camunda:outputParameter name="submitAck">${statusCode == 200}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f_ns</bpmn:incoming><bpmn:incoming>f_retry</bpmn:incoming><bpmn:outgoing>f10</bpmn:outgoing><bpmn:property id="Prop_T_Submit_Decision" name="__targetRef_placeholder" /><bpmn:property id="Prop_T_Submit_UnivList" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Decision_T_Submit"><bpmn:sourceRef>DObjRef_Decision</bpmn:sourceRef><bpmn:targetRef>Prop_T_Submit_Decision</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataInputAssociation id="DIn_UnivList_T_Submit"><bpmn:sourceRef>DObjRef_UnivList</bpmn:sourceRef><bpmn:targetRef>Prop_T_Submit_UnivList</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_AppPackage"><bpmn:targetRef>DObjRef_AppPackage</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_SubmitAck" name="Submit Berhasil?" default="f_ack_ok"><bpmn:incoming>f10</bpmn:incoming><bpmn:outgoing>f_ack_ok</bpmn:outgoing><bpmn:outgoing>f_ack_fail</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_HandleSubmitEscalation" name="Tangani Kegagalan Submit (Cek Portal)"><bpmn:extensionElements><camunda:executionListener event="end" expression="${execution.setVariable('submitRetryCount', (submitRetryCount == null ? 0 : submitRetryCount) + 1)}" /></bpmn:extensionElements><bpmn:incoming>f_ack_fail</bpmn:incoming><bpmn:outgoing>f_esc</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_SubmitRetry" name="Coba Submit Lagi?" default="f_fail"><bpmn:incoming>f_esc</bpmn:incoming><bpmn:outgoing>f_retry</bpmn:outgoing><bpmn:outgoing>f_fail</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_SubmitFailed" name="Submit Gagal Permanen (Eskalasi)"><bpmn:incoming>f_fail</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="T_Track" name="Lacak Hasil Penerimaan" camunda:formRef="form_admission" camunda:formRefBinding="latest"><bpmn:incoming>f_ack_ok</bpmn:incoming><bpmn:outgoing>f11</bpmn:outgoing><bpmn:property id="Prop_T_Track_AppPackage" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_AppPackage_T_Track"><bpmn:sourceRef>DObjRef_AppPackage</bpmn:sourceRef><bpmn:targetRef>Prop_T_Track_AppPackage</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_TrackSLA" name="3 Hari Tanpa Hasil" attachedToRef="T_Track" cancelActivity="false"><bpmn:outgoing>fb1</bpmn:outgoing><bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration></bpmn:timerEventDefinition></bpmn:boundaryEvent>
    <bpmn:serviceTask id="T_RemindAdm" name="Kirim Pengingat Status Aplikasi"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u23F0 [PENGINGAT] Hasil penerimaan belum diperoleh. Pengingat status aplikasi dikirim otomatis."}</camunda:inputParameter><camunda:outputParameter name="logRemindAdm">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>fb1</bpmn:incoming><bpmn:outgoing>fb2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_RemindAdm" name="Pengingat Aplikasi Terkirim"><bpmn:incoming>fb2</bpmn:incoming></bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_Adm" name="Hasil Penerimaan?" default="f_reject"><bpmn:incoming>f11</bpmn:incoming><bpmn:outgoing>f12</bpmn:outgoing><bpmn:outgoing>f_reject</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_RecordLoA" name="Catat Letter of Acceptance"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCC4 [SISTEM] Letter of Acceptance (LoA) tercatat otomatis di sistem."}</camunda:inputParameter><camunda:outputParameter name="logRecordLoA">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f12</bpmn:incoming><bpmn:outgoing>f13</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_LoA"><bpmn:targetRef>DObjRef_LoA</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:serviceTask id="T_Notify" name="Kirim Notifikasi Hasil ke Mahasiswa"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83C\uDF89 Selamat! Aplikasi diterima. Notifikasi hasil telah dikirim ke mahasiswa."}</camunda:inputParameter><camunda:outputParameter name="logNotify">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f13</bpmn:incoming><bpmn:outgoing>f14</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:callActivity id="CA_Enroll" name="Jalankan Onboarding Mahasiswa" calledElement="Process_Onboarding_AppUniv"><bpmn:incoming>f14</bpmn:incoming><bpmn:outgoing>f15b</bpmn:outgoing></bpmn:callActivity>
    <bpmn:endEvent id="End_LoA" name="LoA Diterima"><bpmn:incoming>f15b</bpmn:incoming></bpmn:endEvent>
    <bpmn:serviceTask id="T_NotifyReject" name="Kirim Notifikasi Penolakan dan Tindak Lanjut"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u274C [SISTEM] Aplikasi tidak diterima. Notifikasi hasil dan opsi tindak lanjut dikirim ke mahasiswa."}</camunda:inputParameter><camunda:outputParameter name="logNotifyReject">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f_reject</bpmn:incoming><bpmn:outgoing>f_rej2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_NotAccepted" name="Aplikasi Tidak Diterima"><bpmn:incoming>f_rej2</bpmn:incoming></bpmn:endEvent>
    <bpmn:dataObjectReference id="DObjRef_Docs" name="Dokumen Akademik" dataObjectRef="DObj_Docs" />
    <bpmn:dataObject id="DObj_Docs" />
    <bpmn:dataObjectReference id="DObjRef_Validation" name="Laporan Validasi Kelengkapan" dataObjectRef="DObj_Validation" />
    <bpmn:dataObject id="DObj_Validation" />
    <bpmn:dataObjectReference id="DObjRef_Review" name="Hasil Tinjauan Dokumen" dataObjectRef="DObj_Review" />
    <bpmn:dataObject id="DObj_Review" />
    <bpmn:dataObjectReference id="DObjRef_Decision" name="Keputusan Kesiapan (appDecision)" dataObjectRef="DObj_Decision" />
    <bpmn:dataObject id="DObj_Decision" />
    <bpmn:dataObjectReference id="DObjRef_UnivList" name="Daftar Universitas Target" dataObjectRef="DObj_UnivList" />
    <bpmn:dataObject id="DObj_UnivList" />
    <bpmn:dataObjectReference id="DObjRef_AppPackage" name="Paket Aplikasi Terkirim" dataObjectRef="DObj_AppPackage" />
    <bpmn:dataObject id="DObj_AppPackage" />
    <bpmn:dataObjectReference id="DObjRef_LoA" name="Letter of Acceptance (LoA)" dataObjectRef="DObj_LoA" />
    <bpmn:dataObject id="DObj_LoA" />
    <bpmn:sequenceFlow id="f1" sourceRef="Start_App" targetRef="T_CollectDocs" />
    <bpmn:sequenceFlow id="f2" sourceRef="T_CollectDocs" targetRef="T_AutoCheck" />
    <bpmn:sequenceFlow id="f3" sourceRef="T_AutoCheck" targetRef="T_ReviewDocs" />
    <bpmn:sequenceFlow id="f4" sourceRef="T_ReviewDocs" targetRef="T_EvalApp" />
    <bpmn:sequenceFlow id="f5" sourceRef="T_EvalApp" targetRef="GW_App" />
    <bpmn:sequenceFlow id="f6" sourceRef="GW_App" targetRef="T_ReviseDocs" name="Revisi Dokumen"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${appDecision==&quot;Revise Documents&quot;}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f7" sourceRef="T_ReviseDocs" targetRef="T_AutoCheck" />
    <bpmn:sequenceFlow id="f8" sourceRef="GW_App" targetRef="T_AdjustList" name="Sesuaikan Target"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${appDecision==&quot;Adjust Target&quot;}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f9" sourceRef="T_AdjustList" targetRef="T_ReviewDocs" />
    <bpmn:sequenceFlow id="f_submit" sourceRef="GW_App" targetRef="T_NotifySubmit" name="Submit" />
    <bpmn:sequenceFlow id="f_ns" sourceRef="T_NotifySubmit" targetRef="T_Submit" />
    <bpmn:sequenceFlow id="f10" sourceRef="T_Submit" targetRef="GW_SubmitAck" />
    <bpmn:sequenceFlow id="f_ack_ok" sourceRef="GW_SubmitAck" targetRef="T_Track" name="Berhasil" />
    <bpmn:sequenceFlow id="f_ack_fail" sourceRef="GW_SubmitAck" targetRef="T_HandleSubmitEscalation" name="Gagal Submit"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${submitAck==false}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_esc" sourceRef="T_HandleSubmitEscalation" targetRef="GW_SubmitRetry" />
    <bpmn:sequenceFlow id="f_retry" sourceRef="GW_SubmitRetry" targetRef="T_Submit" name="Coba Lagi (&lt; 3x)"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${submitRetryCount &lt; 3}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f_fail" sourceRef="GW_SubmitRetry" targetRef="End_SubmitFailed" name="Gagal Permanen (&gt;= 3x)" />
    <bpmn:sequenceFlow id="f11" sourceRef="T_Track" targetRef="GW_Adm" />
    <bpmn:sequenceFlow id="f12" sourceRef="GW_Adm" targetRef="T_RecordLoA" name="Diterima"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${admissionResult==&quot;Accepted&quot;}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f13" sourceRef="T_RecordLoA" targetRef="T_Notify" />
    <bpmn:sequenceFlow id="f14" sourceRef="T_Notify" targetRef="CA_Enroll" />
    <bpmn:sequenceFlow id="f15b" sourceRef="CA_Enroll" targetRef="End_LoA" />
    <bpmn:sequenceFlow id="f_reject" sourceRef="GW_Adm" targetRef="T_NotifyReject" name="Ditolak" />
    <bpmn:sequenceFlow id="f_rej2" sourceRef="T_NotifyReject" targetRef="End_NotAccepted" />
    <bpmn:sequenceFlow id="fb1" sourceRef="Bnd_TrackSLA" targetRef="T_RemindAdm" />
    <bpmn:sequenceFlow id="fb2" sourceRef="T_RemindAdm" targetRef="End_RemindAdm" />
  </bpmn:process>
  <bpmn:process id="Process_Onboarding_AppUniv" name="Onboarding Mahasiswa Baru" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="OBA_Start" name="Onboarding Dimulai"><bpmn:outgoing>oba1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="OBA_Welcome" name="Jadwalkan Sesi Orientasi"><bpmn:incoming>oba1</bpmn:incoming><bpmn:outgoing>oba2</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="OBA_Account" name="Aktifkan Akun Mahasiswa" camunda:expression="${true}"><bpmn:incoming>oba2</bpmn:incoming><bpmn:outgoing>oba3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="OBA_End" name="Onboarding Selesai"><bpmn:incoming>oba3</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="oba1" sourceRef="OBA_Start" targetRef="OBA_Welcome" />
    <bpmn:sequenceFlow id="oba2" sourceRef="OBA_Welcome" targetRef="OBA_Account" />
    <bpmn:sequenceFlow id="oba3" sourceRef="OBA_Account" targetRef="OBA_End" />
  </bpmn:process>
