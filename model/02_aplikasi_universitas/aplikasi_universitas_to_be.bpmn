      <bpmndi:BPMNEdge id="di_DIn_Docs_T_AutoCheck" bpmnElement="DIn_Docs_T_AutoCheck"><di:waypoint x="635" y="136" /><di:waypoint x="789" y="690" /></bpmndi:BPMNEdge>
