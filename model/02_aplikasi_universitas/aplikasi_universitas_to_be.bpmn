<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Process_AppUniv_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="2.0">
  <bpmn:collaboration id="Collab_Process_AppUniv_TB">
    <bpmn:participant id="Part_Process_AppUniv_TB" name="Schoters by Ruangguru - Pemrosesan Aplikasi Universitas (To-Be / Terdigitalisasi)" processRef="Process_AppUniv_TB" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AppUniv_TB" name="Pemrosesan Aplikasi Universitas (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_AppUniv_TB">
      <bpmn:lane id="L_Student" name="Calon Mahasiswa">
        <bpmn:flowNodeRef>Start_App</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_PrepBerkas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ReviseDocs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Mentor" name="Academic Mentor">
        <bpmn:flowNodeRef>T_ReviewDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AdjustList</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ApproveL1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_L1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Track</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Approval" name="Komite Kelayakan (Senior Counselor dan Manajer Program)">
        <bpmn:flowNodeRef>T_ApproveL2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_L2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ApproveL3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_L3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_HandleSubmitEscalation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_SubmitRetry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_SubmitFailed</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_System" name="Sistem Schoters (Otomasi)">
        <bpmn:flowNodeRef>T_EvalApp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_App</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_EscalateApproval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ApprovalReminder</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Sub_GenerateDossier</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifySubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Submit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_SubmitAck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RemindAdm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RemindAdm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Adm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RecordLoA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Notify</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_Enroll</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_LoA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_NotAccepted</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_App" name="Ajukan Permintaan Aplikasi Universitas" camunda:formRef="form_app_request" camunda:formRefBinding="latest"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:subProcess id="Sub_PrepBerkas" name="Persiapan dan Verifikasi Berkas (OCR Otomatis)"><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_Docs"><bpmn:targetRef>DObjRef_Docs</bpmn:targetRef></bpmn:dataOutputAssociation><bpmn:startEvent id="PB_Start"><bpmn:outgoing>pb1</bpmn:outgoing></bpmn:startEvent><bpmn:userTask id="PB_Collect" name="Unggah Dokumen Akademik dan Esai"><bpmn:incoming>pb1</bpmn:incoming><bpmn:outgoing>pb2</bpmn:outgoing></bpmn:userTask><bpmn:serviceTask id="PB_OCR" name="Validasi Kelengkapan dan Ekstraksi Data (OCR) Otomatis" camunda:expression="${true}"><bpmn:incoming>pb2</bpmn:incoming><bpmn:outgoing>pb3</bpmn:outgoing></bpmn:serviceTask><bpmn:endEvent id="PB_End"><bpmn:incoming>pb3</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="pb1" sourceRef="PB_Start" targetRef="PB_Collect" /><bpmn:sequenceFlow id="pb2" sourceRef="PB_Collect" targetRef="PB_OCR" /><bpmn:sequenceFlow id="pb3" sourceRef="PB_OCR" targetRef="PB_End" /></bpmn:subProcess>
    <bpmn:userTask id="T_ReviewDocs" name="Tinjau Kualitas Dokumen dan Esai" camunda:formRef="form_review_docs" camunda:formRefBinding="latest"><bpmn:incoming>f2</bpmn:incoming><bpmn:incoming>f_rev2</bpmn:incoming><bpmn:incoming>f_adj2</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing><bpmn:property id="Prop_T_ReviewDocs_Docs" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Docs_T_ReviewDocs"><bpmn:sourceRef>DObjRef_Docs</bpmn:sourceRef><bpmn:targetRef>Prop_T_ReviewDocs_Docs</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="DOut_Review"><bpmn:targetRef>DObjRef_Review</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:businessRuleTask id="T_EvalApp" name="Evaluasi Kesiapan Aplikasi (DMN)" camunda:decisionRef="Decision_Aplikasi" camunda:mapDecisionResult="singleEntry" camunda:resultVariable="appDecision"><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing><bpmn:property id="Prop_T_EvalApp_Review" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Review_T_EvalApp"><bpmn:sourceRef>DObjRef_Review</bpmn:sourceRef><bpmn:targetRef>Prop_T_EvalApp_Review</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_App" name="Kesiapan Aplikasi?" default="f_ok"><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f_rev</bpmn:outgoing><bpmn:outgoing>f_adj</bpmn:outgoing><bpmn:outgoing>f_ok</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ReviseDocs" name="Perbaiki Dokumen Aplikasi"><bpmn:incoming>f_rev</bpmn:incoming><bpmn:incoming>fL1n</bpmn:incoming><bpmn:incoming>fL2n</bpmn:incoming><bpmn:incoming>fL3n</bpmn:incoming><bpmn:outgoing>f_rev2</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_AdjustList" name="Sesuaikan Daftar Universitas Target"><bpmn:incoming>f_adj</bpmn:incoming><bpmn:outgoing>f_adj2</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_ApproveL1" name="Approval L1: Verifikasi Akhir Berkas (Academic Mentor)"><bpmn:extensionElements><camunda:formData><camunda:formField id="l1Approved" label="Setujui di tingkat L1?" type="boolean" /></camunda:formData></bpmn:extensionElements><bpmn:incoming>f_ok</bpmn:incoming><bpmn:outgoing>fL1</bpmn:outgoing><bpmn:property id="Prop_T_ApproveL1_Review" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_Review_T_ApproveL1"><bpmn:sourceRef>DObjRef_Review</bpmn:sourceRef><bpmn:targetRef>Prop_T_ApproveL1_Review</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_L1SLA" name="SLA 1 Hari" attachedToRef="T_ApproveL1" cancelActivity="false"><bpmn:outgoing>fe1</bpmn:outgoing><bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration></bpmn:timerEventDefinition></bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="GW_L1" name="L1 Setuju?" default="fL1n"><bpmn:incoming>fL1</bpmn:incoming><bpmn:outgoing>fL1y</bpmn:outgoing><bpmn:outgoing>fL1n</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ApproveL2" name="Approval L2: Validasi Kelayakan (Senior Counselor)"><bpmn:extensionElements><camunda:formData><camunda:formField id="l2Approved" label="Setujui di tingkat L2?" type="boolean" /></camunda:formData></bpmn:extensionElements><bpmn:incoming>fL1y</bpmn:incoming><bpmn:outgoing>fL2</bpmn:outgoing></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_L2SLA" name="SLA 1 Hari" attachedToRef="T_ApproveL2" cancelActivity="false"><bpmn:outgoing>fe2</bpmn:outgoing><bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration></bpmn:timerEventDefinition></bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="GW_L2" name="L2 Setuju?" default="fL2n"><bpmn:incoming>fL2</bpmn:incoming><bpmn:outgoing>fL2y</bpmn:outgoing><bpmn:outgoing>fL2n</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ApproveL3" name="Approval L3: Persetujuan Final (Manajer Program)"><bpmn:extensionElements><camunda:formData><camunda:formField id="l3Approved" label="Setujui di tingkat L3 (final)?" type="boolean" /></camunda:formData></bpmn:extensionElements><bpmn:incoming>fL2y</bpmn:incoming><bpmn:outgoing>fL3</bpmn:outgoing></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_L3SLA" name="SLA 1 Hari" attachedToRef="T_ApproveL3" cancelActivity="false"><bpmn:outgoing>fe3</bpmn:outgoing><bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P1D</bpmn:timeDuration></bpmn:timerEventDefinition></bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="GW_L3" name="L3 Setuju?" default="fL3n"><bpmn:incoming>fL3</bpmn:incoming><bpmn:outgoing>fL3y</bpmn:outgoing><bpmn:outgoing>fL3n</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_EscalateApproval" name="Kirim Eskalasi: Approval Tertunda"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u23F0 [ESKALASI] Approval aplikasi melewati SLA 1 hari. Pengingat otomatis dikirim ke approver berikutnya."}</camunda:inputParameter><camunda:outputParameter name="logEscalate">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>fe1</bpmn:incoming><bpmn:incoming>fe2</bpmn:incoming><bpmn:incoming>fe3</bpmn:incoming><bpmn:outgoing>fe4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_ApprovalReminder" name="Pengingat Approval Terkirim"><bpmn:incoming>fe4</bpmn:incoming></bpmn:endEvent>
    <bpmn:subProcess id="Sub_GenerateDossier" name="Generate Dokumen dan Tanda Tangan Digital (Auto-PDF)"><bpmn:incoming>fL3y</bpmn:incoming><bpmn:outgoing>fG</bpmn:outgoing><bpmn:dataOutputAssociation id="DOut_SignedPDF"><bpmn:targetRef>DObjRef_SignedPDF</bpmn:targetRef></bpmn:dataOutputAssociation><bpmn:startEvent id="GD_Start"><bpmn:outgoing>gd1</bpmn:outgoing></bpmn:startEvent><bpmn:serviceTask id="GD_Render" name="Render Paket Aplikasi ke PDF Otomatis" camunda:expression="${true}"><bpmn:incoming>gd1</bpmn:incoming><bpmn:outgoing>gd2</bpmn:outgoing></bpmn:serviceTask><bpmn:serviceTask id="GD_Sign" name="Terapkan Tanda Tangan Digital (e-Signature)" camunda:expression="${true}"><bpmn:incoming>gd2</bpmn:incoming><bpmn:outgoing>gd3</bpmn:outgoing></bpmn:serviceTask><bpmn:endEvent id="GD_End"><bpmn:incoming>gd3</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="gd1" sourceRef="GD_Start" targetRef="GD_Render" /><bpmn:sequenceFlow id="gd2" sourceRef="GD_Render" targetRef="GD_Sign" /><bpmn:sequenceFlow id="gd3" sourceRef="GD_Sign" targetRef="GD_End" /></bpmn:subProcess>
    <bpmn:serviceTask id="T_NotifySubmit" name="Beritahu Mahasiswa: Submit Dimulai"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCE8 [SISTEM] Berkas disetujui 3 tingkat dan ditandatangani digital. Memulai submit otomatis ke portal universitas."}</camunda:inputParameter><camunda:outputParameter name="logNotifySubmit">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>fG</bpmn:incoming><bpmn:outgoing>f_ns</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="T_Submit" name="Submit Aplikasi ke Portal Universitas"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83C\uDFDB\uFE0F [SISTEM] Aplikasi telah dikirim otomatis ke portal universitas tujuan."}</camunda:inputParameter><camunda:outputParameter name="logSubmit">${statusCode}</camunda:outputParameter><camunda:outputParameter name="submitAck">${statusCode == 200}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f_ns</bpmn:incoming><bpmn:incoming>f_retry</bpmn:incoming><bpmn:outgoing>f10</bpmn:outgoing><bpmn:property id="Prop_T_Submit_SignedPDF" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_SignedPDF_T_Submit"><bpmn:sourceRef>DObjRef_SignedPDF</bpmn:sourceRef><bpmn:targetRef>Prop_T_Submit_SignedPDF</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_SubmitAck" name="Submit Berhasil?" default="f_ack_ok"><bpmn:incoming>f10</bpmn:incoming><bpmn:outgoing>f_ack_ok</bpmn:outgoing><bpmn:outgoing>f_ack_fail</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_HandleSubmitEscalation" name="Tangani Kegagalan Submit (Cek Portal)"><bpmn:extensionElements><camunda:executionListener event="end" expression="${execution.setVariable('submitRetryCount', (submitRetryCount == null ? 0 : submitRetryCount) + 1)}" /></bpmn:extensionElements><bpmn:incoming>f_ack_fail</bpmn:incoming><bpmn:outgoing>f_esc</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_SubmitRetry" name="Coba Submit Lagi?" default="f_fail"><bpmn:incoming>f_esc</bpmn:incoming><bpmn:outgoing>f_retry</bpmn:outgoing><bpmn:outgoing>f_fail</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_SubmitFailed" name="Submit Gagal Permanen (Eskalasi)"><bpmn:incoming>f_fail</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="T_Track" name="Lacak Hasil Penerimaan" camunda:formRef="form_admission" camunda:formRefBinding="latest"><bpmn:incoming>f_ack_ok</bpmn:incoming><bpmn:outgoing>f11</bpmn:outgoing></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_TrackSLA" name="3 Hari Tanpa Hasil" attachedToRef="T_Track" cancelActivity="false"><bpmn:outgoing>fb1</bpmn:outgoing><bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration></bpmn:timerEventDefinition></bpmn:boundaryEvent>
    <bpmn:serviceTask id="T_RemindAdm" name="Kirim Pengingat Status Aplikasi"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u23F0 [PENGINGAT] Hasil penerimaan belum diperoleh. Pengingat status aplikasi dikirim otomatis."}</camunda:inputParameter><camunda:outputParameter name="logRemindAdm">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>fb1</bpmn:incoming><bpmn:outgoing>fb2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_RemindAdm" name="Pengingat Aplikasi Terkirim"><bpmn:incoming>fb2</bpmn:incoming></bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_Adm" name="Hasil Penerimaan?" default="f_reject"><bpmn:incoming>f11</bpmn:incoming><bpmn:outgoing>f12</bpmn:outgoing><bpmn:outgoing>f_reject</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_RecordLoA" name="Catat Letter of Acceptance"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.tel