<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd" xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_Visa" name="Keputusan Jalur Visa" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_Visa" name="Keputusan Jalur Pengajuan Visa" camunda:historyTimeToLive="P180D">
    <decisionTable id="DT_Decision_Visa" hitPolicy="UNIQUE">
      <input id="in0" label="Dokumen Lengkap">
        <inputExpression id="ie0" typeRef="boolean"><text>documentsComplete</text></inputExpression>
      </input>
      <input id="in1" label="Bukti Finansial Valid">
        <inputExpression id="ie1" typeRef="boolean"><text>financialProofValid</text></inputExpression>
      </input>
      <input id="in2" label="Kategori Risiko Negara">
        <inputExpression id="ie2" typeRef="string"><text>destinationRisk</text></inputExpression>
      </input>
      <output id="out_dec" label="Keputusan" name="visaDecision" typeRef="string" />
      <rule id="r0">
        <inputEntry id="r0i0"><text>false</text></inputEntry>
        <inputEntry id="r0i1"><text></text></inputEntry>
        <inputEntry id="r0i2"><text></text></inputEntry>
        <outputEntry id="r0o"><text>&quot;Complete Documents&quot;</text></outputEntry>
      </rule>
      <rule id="r1">
        <inputEntry id="r1i0"><text>true</text></inputEntry>
        <inputEntry id="r1i1"><text>false</text></inputEntry>
        <inputEntry id="r1i2"><text></text></inputEntry>
        <outputEntry id="r1o"><text>&quot;Resubmit Financial Proof&quot;</text></outputEntry>
      </rule>
      <rule id="r2">
        <inputEntry id="r2i0"><text>true</text></inputEntry>
        <inputEntry id="r2i1"><text>true</text></inputEntry>
        <inputEntry id="r2i2"><text>&quot;High&quot;</text></inputEntry>
        <outputEntry id="r2o"><text>&quot;Schedule Interview&quot;</text></outputEntry>
      </rule>
      <rule id="r3">
        <inputEntry id="r3i0"><text>true</text></inputEntry>
        <inputEntry id="r3i1"><text>true</text></inputEntry>
        <inputEntry id="r3i2"><text>&quot;Low&quot;</text></inputEntry>
        <outputEntry id="r3o"><text>&quot;Submit&quot;</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
