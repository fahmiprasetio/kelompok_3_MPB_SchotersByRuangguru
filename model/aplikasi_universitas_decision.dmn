<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd" xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_Aplikasi" name="Keputusan Kesiapan Aplikasi" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_Aplikasi" name="Keputusan Kesiapan Aplikasi Universitas" camunda:historyTimeToLive="P180D">
    <decisionTable id="DT_Decision_Aplikasi" hitPolicy="UNIQUE">
      <input id="in0" label="Esai &amp; Dokumen Siap">
        <inputExpression id="ie0" typeRef="boolean"><text>essayReady</text></inputExpression>
      </input>
      <input id="in1" label="IPK / GPA">
        <inputExpression id="ie1" typeRef="double"><text>gpa</text></inputExpression>
      </input>
      <input id="in2" label="Tier Universitas Target">
        <inputExpression id="ie2" typeRef="string"><text>targetTier</text></inputExpression>
      </input>
      <output id="out_dec" label="Keputusan" name="appDecision" typeRef="string" />
      <rule id="r0">
        <inputEntry id="r0i0"><text>false</text></inputEntry>
        <inputEntry id="r0i1"><text></text></inputEntry>
        <inputEntry id="r0i2"><text></text></inputEntry>
        <outputEntry id="r0o"><text>&quot;Revise Documents&quot;</text></outputEntry>
      </rule>
      <rule id="r1">
        <inputEntry id="r1i0"><text>true</text></inputEntry>
        <inputEntry id="r1i1"><text>&gt;= 3.5</text></inputEntry>
        <inputEntry id="r1i2"><text></text></inputEntry>
        <outputEntry id="r1o"><text>&quot;Submit&quot;</text></outputEntry>
      </rule>
      <rule id="r2">
        <inputEntry id="r2i0"><text>true</text></inputEntry>
        <inputEntry id="r2i1"><text>&lt; 3.5</text></inputEntry>
        <inputEntry id="r2i2"><text>&quot;Top&quot;</text></inputEntry>
        <outputEntry id="r2o"><text>&quot;Adjust Target&quot;</text></outputEntry>
      </rule>
      <rule id="r3">
        <inputEntry id="r3i0"><text>true</text></inputEntry>
        <inputEntry id="r3i1"><text>&lt; 3.5</text></inputEntry>
        <inputEntry id="r3i2"><text>&quot;Mid&quot;,&quot;Safe&quot;</text></inputEntry>
        <outputEntry id="r3o"><text>&quot;Submit&quot;</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
