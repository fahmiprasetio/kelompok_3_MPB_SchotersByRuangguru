<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd" xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_Refund" name="Keputusan Kelayakan Refund" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_Refund" name="Keputusan Kelayakan Refund" camunda:historyTimeToLive="P180D">
    <decisionTable id="DT_Decision_Refund" hitPolicy="UNIQUE">
      <input id="in0" label="Dalam Masa Cooling-Off">
        <inputExpression id="ie0" typeRef="boolean"><text>withinCoolingOff</text></inputExpression>
      </input>
      <input id="in1" label="Kategori Alasan">
        <inputExpression id="ie1" typeRef="string"><text>reasonCategory</text></inputExpression>
      </input>
      <input id="in2" label="Persentase Layanan Terpakai">
        <inputExpression id="ie2" typeRef="double"><text>serviceUsedPercent</text></inputExpression>
      </input>
      <output id="out_dec" label="Keputusan" name="refundDecision" typeRef="string" />
      <rule id="r0">
        <inputEntry id="r0i0"><text>true</text></inputEntry>
        <inputEntry id="r0i1"><text></text></inputEntry>
        <inputEntry id="r0i2"><text></text></inputEntry>
        <outputEntry id="r0o"><text>&quot;Full Refund&quot;</text></outputEntry>
      </rule>
      <rule id="r1">
        <inputEntry id="r1i0"><text>false</text></inputEntry>
        <inputEntry id="r1i1"><text>&quot;Valid&quot;</text></inputEntry>
        <inputEntry id="r1i2"><text>&lt;= 50</text></inputEntry>
        <outputEntry id="r1o"><text>&quot;Partial Refund&quot;</text></outputEntry>
      </rule>
      <rule id="r2">
        <inputEntry id="r2i0"><text>false</text></inputEntry>
        <inputEntry id="r2i1"><text>&quot;Valid&quot;</text></inputEntry>
        <inputEntry id="r2i2"><text>&gt; 50</text></inputEntry>
        <outputEntry id="r2o"><text>&quot;No Refund&quot;</text></outputEntry>
      </rule>
      <rule id="r3">
        <inputEntry id="r3i0"><text>false</text></inputEntry>
        <inputEntry id="r3i1"><text>&quot;Invalid&quot;</text></inputEntry>
        <inputEntry id="r3i2"><text></text></inputEntry>
        <outputEntry id="r3o"><text>&quot;No Refund&quot;</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
