<?xml version='1.0' encoding='UTF-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Refund_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collab_Refund_TB">
    <bpmn:participant id="Part_Refund_TB" name="Schoters by Ruangguru - Refund / Pembatalan (To-Be / Terdigitalisasi)" processRef="Process_Refund_TB"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_Refund_TB" name="Refund / Pembatalan Program (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_Refund_TB">
      <bpmn:lane id="L_Mhs" name="Mahasiswa">
        <bpmn:flowNodeRef>Start_Refund</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_FixData</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ConfirmAccount</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ConfirmReceipt</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_CS" name="Customer Service">
        <bpmn:flowNodeRef>T_VerifyDocs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Docs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Fin" name="Tim Finance">
        <bpmn:flowNodeRef>T_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ApprovePartial</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_ProcessPayment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Bnd_PaySLA</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Mgr" name="Manajer Finance">
        <bpmn:flowNodeRef>T_ApproveFull</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Sys" name="Sistem Schoters">
        <bpmn:flowNodeRef>T_Validate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Eval</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Dec</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Reject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_Record</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_NotifyDone</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CA_Audit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_Done</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_RemindPay</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_RemindPay</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Refund" name="Ajukan Permintaan Refund" camunda:formRef="form_refund_request" camunda:formRefBinding="latest">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_Validate" name="Validasi Otomatis Permintaan" camunda:expression="${true}" camunda:resultVariable="dataValid">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_DRB_Tiket">
        <bpmn:targetRef>DRB_Tiket</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_VerifyDocs" name="Verifikasi Dokumen Pendukung" camunda:formRef="form_doc_verify" camunda:formRefBinding="latest">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
      <bpmn:property id="Prop_T_VerifyDocs_DRB_Tiket" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Tiket_T_VerifyDocs">
        <bpmn:sourceRef>DRB_Tiket</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_VerifyDocs_DRB_Tiket</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_DRB_Verifikasi">
        <bpmn:targetRef>DRB_Verifikasi</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Docs" name="Dokumen Lengkap?" default="f6">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_FixData" name="Perbaiki Data Permintaan">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="T_Review" name="Tinjau Permintaan Refund" camunda:formRef="form_refund_review" camunda:formRefBinding="latest">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
      <bpmn:property id="Prop_T_Review_DRB_Verifikasi" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Verifikasi_T_Review">
        <bpmn:sourceRef>DRB_Verifikasi</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_Review_DRB_Verifikasi</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_DRB_Tinjauan">
        <bpmn:targetRef>DRB_Tinjauan</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="T_Eval" name="Evaluasi Kelayakan Refund (DMN)" camunda:resultVariable="refundDecision" camunda:decisionRef="Decision_Refund" camunda:mapDecisionResult="singleEntry">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:property id="Prop_T_Eval_DRB_Tinjauan" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Tinjauan_T_Eval">
        <bpmn:sourceRef>DRB_Tinjauan</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_Eval_DRB_Tinjauan</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_DRB_Keputusan">
        <bpmn:targetRef>DRB_Keputusan</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_Dec" name="Keputusan Refund?" default="f11">
      <bpmn:incoming>f8</bpmn:incoming>
      <bpmn:outgoing>f9</bpmn:outgoing>
      <bpmn:outgoing>f10</bpmn:outgoing>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ApproveFull" name="Setujui Refund Penuh (Manajer)">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
      <bpmn:property id="Prop_T_ApproveFull_DRB_Keputusan" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Keputusan_T_ApproveFull">
        <bpmn:sourceRef>DRB_Keputusan</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_ApproveFull_DRB_Keputusan</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_ApprovePartial" name="Setujui Refund Sebagian">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
      <bpmn:property id="Prop_T_ApprovePartial_DRB_Keputusan" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Keputusan_T_ApprovePartial">
        <bpmn:sourceRef>DRB_Keputusan</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_ApprovePartial_DRB_Keputusan</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_NotifyReject" name="Kirim Notifikasi Penolakan" camunda:expression="${true}">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_DRB_EmailTolak">
        <bpmn:targetRef>DRB_EmailTolak</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_Reject" name="Refund Ditolak">
      <bpmn:incoming>f20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_Join">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ConfirmAccount" name="Konfirmasi Rekening Tujuan" camunda:formRef="form_account_confirm" camunda:formRefBinding="latest">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_DRB_Rekening">
        <bpmn:targetRef>DRB_Rekening</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_ProcessPayment" name="Proses Pembayaran Refund">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
      <bpmn:property id="Prop_T_ProcessPayment_DRB_Rekening" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Rekening_T_ProcessPayment">
        <bpmn:sourceRef>DRB_Rekening</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_ProcessPayment_DRB_Rekening</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_DRB_Bukti">
        <bpmn:targetRef>DRB_Bukti</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_PaySLA" name="2 Hari Tanpa Pembayaran" attachedToRef="T_ProcessPayment" cancelActivity="false">
      <bpmn:outgoing>fb1</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="T_RemindPay" name="Kirim Pengingat Pembayaran Refund" camunda:expression="${true}">
      <bpmn:incoming>fb1</bpmn:incoming>
      <bpmn:outgoing>fb2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_RemindPay" name="Pengingat Pembayaran Terkirim">
      <bpmn:incoming>fb2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="T_Record" name="Catat Transaksi Refund" camunda:expression="${true}">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:property id="Prop_T_Record_DRB_Bukti" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Bukti_T_Record">
        <bpmn:sourceRef>DRB_Bukti</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_Record_DRB_Bukti</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_DRB_Catatan">
        <bpmn:targetRef>DRB_Catatan</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_ConfirmReceipt" name="Konfirmasi Penerimaan Dana">
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_NotifyDone" name="Kirim Notifikasi Refund Selesai" camunda:expression="${true}">
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
      <bpmn:property id="Prop_T_NotifyDone_DRB_Catatan" name="__targetRef_placeholder"/>
      <bpmn:dataInputAssociation id="DIn_DRB_Catatan_T_NotifyDone">
        <bpmn:sourceRef>DRB_Catatan</bpmn:sourceRef>
        <bpmn:targetRef>Prop_T_NotifyDone_DRB_Catatan</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_DRB_Konfirmasi">
        <bpmn:targetRef>DRB_Konfirmasi</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:callActivity id="CA_Audit" name="Jalankan Audit &amp; Arsip Refund" calledElement="Process_RefundAudit">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="End_Done" name="Refund Selesai">
      <bpmn:incoming>f21</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start_Refund" targetRef="T_Validate"/>
    <bpmn:sequenceFlow id="f2" sourceRef="T_Validate" targetRef="T_VerifyDocs"/>
    <bpmn:sequenceFlow id="f3" sourceRef="T_VerifyDocs" targetRef="GW_Docs"/>
    <bpmn:sequenceFlow id="f4" sourceRef="GW_Docs" targetRef="T_FixData" name="Dokumen Tidak Lengkap">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${dokumenLengkap == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f5" sourceRef="T_FixData" targetRef="T_VerifyDocs"/>
    <bpmn:sequenceFlow id="f6" sourceRef="GW_Docs" targetRef="T_Review" name="Dokumen Lengkap"/>
    <bpmn:sequenceFlow id="f7" sourceRef="T_Review" targetRef="T_Eval"/>
    <bpmn:sequenceFlow id="f8" sourceRef="T_Eval" targetRef="GW_Dec"/>
    <bpmn:sequenceFlow id="f9" sourceRef="GW_Dec" targetRef="T_ApproveFull" name="Refund Penuh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${refundDecision=='Full Refund'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f10" sourceRef="GW_Dec" targetRef="T_ApprovePartial" name="Refund Sebagian">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${refundDecision=='Partial Refund'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f11" sourceRef="GW_Dec" targetRef="T_NotifyReject" name="Tanpa Refund"/>
    <bpmn:sequenceFlow id="f12" sourceRef="T_ApproveFull" targetRef="GW_Join"/>
    <bpmn:sequenceFlow id="f13" sourceRef="T_ApprovePartial" targetRef="GW_Join"/>
    <bpmn:sequenceFlow id="f14" sourceRef="GW_Join" targetRef="T_ConfirmAccount"/>
    <bpmn:sequenceFlow id="f15" sourceRef="T_ConfirmAccount" targetRef="T_ProcessPayment"/>
    <bpmn:sequenceFlow id="f16" sourceRef="T_ProcessPayment" targetRef="T_Record"/>
    <bpmn:sequenceFlow id="f17" sourceRef="T_Record" targetRef="T_ConfirmReceipt"/>
    <bpmn:sequenceFlow id="f18" sourceRef="T_ConfirmReceipt" targetRef="T_NotifyDone"/>
    <bpmn:sequenceFlow id="f19" sourceRef="T_NotifyDone" targetRef="CA_Audit"/>
    <bpmn:sequenceFlow id="f21" sourceRef="CA_Audit" targetRef="End_Done"/>
    <bpmn:sequenceFlow id="fb1" sourceRef="Bnd_PaySLA" targetRef="T_RemindPay"/>
    <bpmn:sequenceFlow id="fb2" sourceRef="T_RemindPay" targetRef="End_RemindPay"/>
    <bpmn:sequenceFlow id="f20" sourceRef="T_NotifyReject" targetRef="End_Reject"/>
    <bpmn:dataObjectReference id="DRB_Tiket" name="Tiket Refund" dataObjectRef="DOB_Tiket"/>
    <bpmn:dataObject id="DOB_Tiket"/>
    <bpmn:dataObjectReference id="DRB_Verifikasi" name="Hasil Verifikasi Dokumen" dataObjectRef="DOB_Verifikasi"/>
    <bpmn:dataObject id="DOB_Verifikasi"/>
    <bpmn:dataObjectReference id="DRB_Tinjauan" name="Hasil Tinjauan Refund" dataObjectRef="DOB_Tinjauan"/>
    <bpmn:dataObject id="DOB_Tinjauan"/>
    <bpmn:dataObjectReference id="DRB_Keputusan" name="Keputusan Refund (DMN)" dataObjectRef="DOB_Keputusan"/>
    <bpmn:dataObject id="DOB_Keputusan"/>
    <bpmn:dataObjectReference id="DRB_Rekening" name="Data Rekening Tujuan" dataObjectRef="DOB_Rekening"/>
    <bpmn:dataObject id="DOB_Rekening"/>
    <bpmn:dataObjectReference id="DRB_Bukti" name="Bukti Pembayaran" dataObjectRef="DOB_Bukti"/>
    <bpmn:dataObject id="DOB_Bukti"/>
    <bpmn:dataObjectReference id="DRB_Catatan" name="Catatan Transaksi Refund" dataObjectRef="DOB_Catatan"/>
    <bpmn:dataObject id="DOB_Catatan"/>
    <bpmn:dataObjectReference id="DRB_EmailTolak" name="Email Penolakan" dataObjectRef="DOB_EmailTolak"/>
    <bpmn:dataObject id="DOB_EmailTolak"/>
    <bpmn:dataObjectReference id="DRB_Konfirmasi" name="Email Konfirmasi Selesai" dataObjectRef="DOB_Konfirmasi"/>
    <bpmn:dataObject id="DOB_Konfirmasi"/>
  </bpmn:process>
  <bpmn:process id="Process_RefundAudit" name="Audit &amp; Arsip Refund" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="RA_Start" name="Audit Dimulai"><bpmn:outgoing>ra1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="RA_Review" name="Tinjau Kesesuaian Transaksi"><bpmn:incoming>ra1</bpmn:incoming><bpmn:outgoing>ra2</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="RA_Archive" name="Arsipkan Bukti Refund" camunda:expression="${true}"><bpmn:incoming>ra2</bpmn:incoming><bpmn:outgoing>ra3</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="RA_End" name="Audit Selesai"><bpmn:incoming>ra3</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="ra1" sourceRef="RA_Start" targetRef="RA_Review"/>
    <bpmn:sequenceFlow id="ra2" sourceRef="RA_Review" targetRef="RA_Archive"/>
    <bpmn:sequenceFlow id="ra3" sourceRef="RA_Archive" targetRef="RA_End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag">
    <bpmndi:BPMNPlane id="Plane" bpmnElement="Collab_Refund_TB">
      <bpmndi:BPMNShape id="di_Part_Refund_TB" bpmnElement="Part_Refund_TB" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="2960" height="800"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Sys" bpmnElement="L_Sys" isHorizontal="true">
        <dc:Bounds x="190" y="720" width="2930" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Mgr" bpmnElement="L_Mgr" isHorizontal="true">
        <dc:Bounds x="190" y="560" width="2930" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Fin" bpmnElement="L_Fin" isHorizontal="true">
        <dc:Bounds x="190" y="400" width="2930" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_CS" bpmnElement="L_CS" isHorizontal="true">
        <dc:Bounds x="190" y="240" width="2930" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Mhs" bpmnElement="L_Mhs" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="2930" height="160"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_Start_Refund" bpmnElement="Start_Refund">
        <dc:Bounds x="232" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Validate" bpmnElement="T_Validate">
        <dc:Bounds x="320" y="760" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_VerifyDocs" bpmnElement="T_VerifyDocs">
        <dc:Bounds x="500" y="280" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Docs" bpmnElement="GW_Docs" isMarkerVisible="true">
        <dc:Bounds x="700" y="295" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_FixData" bpmnElement="T_FixData">
        <dc:Bounds x="640" y="120" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Review" bpmnElement="T_Review">
        <dc:Bounds x="900" y="440" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_Eval" bpmnElement="T_Eval">
        <dc:Bounds x="1080" y="760" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Dec" bpmnElement="GW_Dec" isMarkerVisible="true">
        <dc:Bounds x="1300" y="775" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ApproveFull" bpmnElement="T_ApproveFull">
        <dc:Bounds x="1480" y="600" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_ApprovePartial" bpmnElement="T_ApprovePartial">
        <dc:Bounds x="1480" y="440" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_T_NotifyReject" bpmnElement="T_NotifyReject">
        <dc:Bounds x="1480" y="760" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_End_Reject" bpmnElement="End_Reject">
        <dc:Bounds x="1722" y="782" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Join" bpmnElement="GW_Join" isMarkerVisible="true">
        <dc:Bounds x="1720" y="455" width="50" height="50"/>
