<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Refund_TB" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Collab_Refund_TB"><bpmn:participant id="Part_Refund_TB" name="Schoters by Ruangguru - Refund / Pembatalan (To-Be / Terdigitalisasi)" processRef="Process_Refund_TB" /></bpmn:collaboration>
  <bpmn:error id="Err_Payment" name="Pembayaran Gagal" errorCode="PAYMENT_FAILED" />
  <bpmn:process id="Process_Refund_TB" name="Refund / Pembatalan Program (To-Be)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_Refund_TB">
      <bpmn:lane id="L_Mhs" name="Mahasiswa"><bpmn:flowNodeRef>Start_Refund</bpmn:flowNodeRef><bpmn:flowNodeRef>T_FixData</bpmn:flowNodeRef><bpmn:flowNodeRef>T_ConfirmAccount</bpmn:flowNodeRef><bpmn:flowNodeRef>T_ConfirmReceipt</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_CS" name="Customer Service"><bpmn:flowNodeRef>T_VerifyDocs</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_Docs</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_Fin" name="Tim Finance"><bpmn:flowNodeRef>T_Review</bpmn:flowNodeRef><bpmn:flowNodeRef>Bnd_ReviewSLA</bpmn:flowNodeRef><bpmn:flowNodeRef>T_ApprovePartial</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_Join</bpmn:flowNodeRef><bpmn:flowNodeRef>T_ProcessPayment</bpmn:flowNodeRef><bpmn:flowNodeRef>Bnd_PaymentError</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_Mgr" name="Manajer Finance"><bpmn:flowNodeRef>T_ApproveFull</bpmn:flowNodeRef><bpmn:flowNodeRef>T_HandlePaymentFail</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_Sys" name="Sistem Schoters"><bpmn:flowNodeRef>T_Validate</bpmn:flowNodeRef><bpmn:flowNodeRef>T_AckReceived</bpmn:flowNodeRef><bpmn:flowNodeRef>T_RemindReview</bpmn:flowNodeRef><bpmn:flowNodeRef>End_Reminder</bpmn:flowNodeRef><bpmn:flowNodeRef>T_Eval</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_Dec</bpmn:flowNodeRef><bpmn:flowNodeRef>T_NotifyApproved</bpmn:flowNodeRef><bpmn:flowNodeRef>T_NotifyReject</bpmn:flowNodeRef><bpmn:flowNodeRef>End_Reject</bpmn:flowNodeRef><bpmn:flowNodeRef>T_Record</bpmn:flowNodeRef><bpmn:flowNodeRef>T_NotifyDone</bpmn:flowNodeRef><bpmn:flowNodeRef>End_Done</bpmn:flowNodeRef></bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_Refund" name="Ajukan Permintaan Refund" camunda:formRef="form_refund_request" camunda:formRefBinding="latest"><bpmn:outgoing>f1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="T_Validate" name="Validasi Otomatis Permintaan" camunda:expression="${true}" camunda:resultVariable="dataValid"><bpmn:incoming>f1</bpmn:incoming><bpmn:outgoing>f2</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_DRB_Tiket"><bpmn:targetRef>DRB_Tiket</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:serviceTask id="T_AckReceived" name="Kirim Notifikasi Penerimaan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCE5 [Schoters] Permintaan refund Anda telah kami terima dan sedang diverifikasi. Mohon tunggu informasi selanjutnya."}</camunda:inputParameter><camunda:outputParameter name="logAckReceived">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f2</bpmn:incoming><bpmn:outgoing>f2b</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="T_VerifyDocs" name="Verifikasi Dokumen Pendukung" camunda:formRef="form_doc_verify" camunda:formRefBinding="latest"><bpmn:incoming>f2b</bpmn:incoming><bpmn:incoming>f5</bpmn:incoming><bpmn:outgoing>f3</bpmn:outgoing><bpmn:property id="Prop_T_VerifyDocs_DRB_Tiket" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Tiket_T_VerifyDocs"><bpmn:sourceRef>DRB_Tiket</bpmn:sourceRef><bpmn:targetRef>Prop_T_VerifyDocs_DRB_Tiket</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_DRB_Verifikasi"><bpmn:targetRef>DRB_Verifikasi</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Docs" name="Dokumen Lengkap?" default="f6"><bpmn:incoming>f3</bpmn:incoming><bpmn:outgoing>f4</bpmn:outgoing><bpmn:outgoing>f6</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_FixData" name="Perbaiki Data Permintaan"><bpmn:incoming>f4</bpmn:incoming><bpmn:outgoing>f5</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="T_Review" name="Tinjau Permintaan Refund" camunda:formRef="form_refund_review" camunda:formRefBinding="latest"><bpmn:incoming>f6</bpmn:incoming><bpmn:outgoing>f7</bpmn:outgoing><bpmn:property id="Prop_T_Review_DRB_Verifikasi" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Verifikasi_T_Review"><bpmn:sourceRef>DRB_Verifikasi</bpmn:sourceRef><bpmn:targetRef>Prop_T_Review_DRB_Verifikasi</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_DRB_Tinjauan"><bpmn:targetRef>DRB_Tinjauan</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_ReviewSLA" name="SLA Tinjauan Terlampaui" attachedToRef="T_Review" cancelActivity="false"><bpmn:outgoing>rb1</bpmn:outgoing><bpmn:timerEventDefinition><bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P2D</bpmn:timeDuration></bpmn:timerEventDefinition></bpmn:boundaryEvent>
    <bpmn:serviceTask id="T_RemindReview" name="Kirim Pengingat Tinjauan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u23F0 [Schoters] Pengingat: permintaan refund masih menunggu peninjauan melebihi SLA. Mohon segera ditindaklanjuti tim Finance."}</camunda:inputParameter><camunda:outputParameter name="logRemindReview">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>rb1</bpmn:incoming><bpmn:outgoing>rb2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End_Reminder" name="Pengingat Terkirim"><bpmn:incoming>rb2</bpmn:incoming></bpmn:endEvent>
    <bpmn:businessRuleTask id="T_Eval" name="Evaluasi Kelayakan Refund (DMN)" camunda:resultVariable="refundDecision" camunda:decisionRef="Decision_Refund" camunda:mapDecisionResult="singleEntry"><bpmn:incoming>f7</bpmn:incoming><bpmn:outgoing>f8</bpmn:outgoing><bpmn:property id="Prop_T_Eval_DRB_Tinjauan" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Tinjauan_T_Eval"><bpmn:sourceRef>DRB_Tinjauan</bpmn:sourceRef><bpmn:targetRef>Prop_T_Eval_DRB_Tinjauan</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_DRB_Keputusan"><bpmn:targetRef>DRB_Keputusan</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="GW_Dec" name="Keputusan Refund?" default="f11"><bpmn:incoming>f8</bpmn:incoming><bpmn:outgoing>f9</bpmn:outgoing><bpmn:outgoing>f10</bpmn:outgoing><bpmn:outgoing>f11</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="T_ApproveFull" name="Setujui Refund Penuh (Manajer)"><bpmn:incoming>f9</bpmn:incoming><bpmn:outgoing>f12</bpmn:outgoing><bpmn:property id="Prop_T_ApproveFull_DRB_Keputusan" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Keputusan_T_ApproveFull"><bpmn:sourceRef>DRB_Keputusan</bpmn:sourceRef><bpmn:targetRef>Prop_T_ApproveFull_DRB_Keputusan</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:userTask id="T_ApprovePartial" name="Setujui Refund Sebagian"><bpmn:incoming>f10</bpmn:incoming><bpmn:outgoing>f13</bpmn:outgoing><bpmn:property id="Prop_T_ApprovePartial_DRB_Keputusan" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Keputusan_T_ApprovePartial"><bpmn:sourceRef>DRB_Keputusan</bpmn:sourceRef><bpmn:targetRef>Prop_T_ApprovePartial_DRB_Keputusan</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:serviceTask id="T_NotifyReject" name="Kirim Notifikasi Penolakan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u274C [Schoters] Mohon maaf, permintaan refund Anda tidak memenuhi kriteria kebijakan sehingga tidak dapat disetujui. Silakan hubungi tim kami untuk informasi lebih lanjut."}</camunda:inputParameter><camunda:outputParameter name="logNotifyReject">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f11</bpmn:incoming><bpmn:outgoing>f20</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_DRB_EmailTolak"><bpmn:targetRef>DRB_EmailTolak</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:endEvent id="End_Reject" name="Refund Ditolak"><bpmn:incoming>f20</bpmn:incoming></bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_Join"><bpmn:incoming>f12</bpmn:incoming><bpmn:incoming>f13</bpmn:incoming><bpmn:outgoing>f14</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="T_NotifyApproved" name="Kirim Notifikasi Persetujuan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCE8 [Schoters] Kabar baik! Permintaan refund Anda telah disetujui. Mohon konfirmasi rekening tujuan agar dana dapat ditransfer."}</camunda:inputParameter><camunda:outputParameter name="logNotifyApproved">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f14</bpmn:incoming><bpmn:outgoing>f14b</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="T_ConfirmAccount" name="Konfirmasi Rekening Tujuan" camunda:formRef="form_account_confirm" camunda:formRefBinding="latest"><bpmn:incoming>f14b</bpmn:incoming><bpmn:outgoing>f15</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_DRB_Rekening"><bpmn:targetRef>DRB_Rekening</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="T_ProcessPayment" name="Proses Pembayaran Refund"><bpmn:incoming>f15</bpmn:incoming><bpmn:incoming>pe2</bpmn:incoming><bpmn:outgoing>f16</bpmn:outgoing><bpmn:property id="Prop_T_ProcessPayment_DRB_Rekening" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Rekening_T_ProcessPayment"><bpmn:sourceRef>DRB_Rekening</bpmn:sourceRef><bpmn:targetRef>Prop_T_ProcessPayment_DRB_Rekening</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_DRB_Bukti"><bpmn:targetRef>DRB_Bukti</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:boundaryEvent id="Bnd_PaymentError" name="Pembayaran Gagal" attachedToRef="T_ProcessPayment"><bpmn:outgoing>pe1</bpmn:outgoing><bpmn:errorEventDefinition errorRef="Err_Payment" /></bpmn:boundaryEvent>
    <bpmn:userTask id="T_HandlePaymentFail" name="Tangani Kegagalan Pembayaran"><bpmn:incoming>pe1</bpmn:incoming><bpmn:outgoing>pe2</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="T_Record" name="Catat Transaksi Refund" camunda:expression="${true}"><bpmn:incoming>f16</bpmn:incoming><bpmn:outgoing>f17</bpmn:outgoing><bpmn:property id="Prop_T_Record_DRB_Bukti" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Bukti_T_Record"><bpmn:sourceRef>DRB_Bukti</bpmn:sourceRef><bpmn:targetRef>Prop_T_Record_DRB_Bukti</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_DRB_Catatan"><bpmn:targetRef>DRB_Catatan</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:userTask id="T_ConfirmReceipt" name="Konfirmasi Penerimaan Dana"><bpmn:incoming>f17</bpmn:incoming><bpmn:outgoing>f18</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="T_NotifyDone" name="Kirim Notifikasi Refund Selesai"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u2705 [Schoters] Refund Anda telah selesai diproses dan dana telah ditransfer ke rekening tujuan. Terima kasih telah menggunakan layanan kami."}</camunda:inputParameter><camunda:outputParameter name="logNotifyDone">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>f18</bpmn:incoming><bpmn:outgoing>f19</bpmn:outgoing><bpmn:property id="Prop_T_NotifyDone_DRB_Catatan" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DRB_Catatan_T_NotifyDone"><bpmn:sourceRef>DRB_Catatan</bpmn:sourceRef><bpmn:targetRef>Prop_T_NotifyDone_DRB_Catatan</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_DRB_Konfirmasi"><bpmn:targetRef>DRB_Konfirmasi</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:endEvent id="End_Done" name="Refund Selesai"><bpmn:incoming>f19</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="Start_Refund" targetRef="T_Validate" />
    <bpmn:sequenceFlow id="f2" sourceRef="T_Validate" targetRef="T_AckReceived" />
    <bpmn:sequenceFlow id="f2b" sourceRef="T_AckReceived" targetRef="T_VerifyDocs" />
    <bpmn:sequenceFlow id="f3" sourceRef="T_VerifyDocs" targetRef="GW_Docs" />
    <bpmn:sequenceFlow id="f4" sourceRef="GW_Docs" targetRef="T_FixData" name="Dokumen Tidak Lengkap"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${dokumenLengkap == false}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f5" sourceRef="T_FixData" targetRef="T_VerifyDocs" />
    <bpmn:sequenceFlow id="f6" sourceRef="GW_Docs" targetRef="T_Review" name="Dokumen Lengkap" />
    <bpmn:sequenceFlow id="f7" sourceRef="T_Review" targetRef="T_Eval" />
    <bpmn:sequenceFlow id="rb1" sourceRef="Bnd_ReviewSLA" targetRef="T_RemindReview" />
    <bpmn:sequenceFlow id="rb2" sourceRef="T_RemindReview" targetRef="End_Reminder" />
    <bpmn:sequenceFlow id="f8" sourceRef="T_Eval" targetRef="GW_Dec" />
    <bpmn:sequenceFlow id="f9" sourceRef="GW_Dec" targetRef="T_ApproveFull" name="Refund Penuh"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${refundDecision=='Full Refund'}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f10" sourceRef="GW_Dec" targetRef="T_ApprovePartial" name="Refund Sebagian"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${refundDecision=='Partial Refund'}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f11" sourceRef="GW_Dec" targetRef="T_NotifyReject" name="Tanpa Refund" />
    <bpmn:sequenceFlow id="f12" sourceRef="T_ApproveFull" targetRef="GW_Join" />
    <bpmn:sequenceFlow id="f13" sourceRef="T_ApprovePartial" targetRef="GW_Join" />
    <bpmn:sequenceFlow id="f14" sourceRef="GW_Join" targetRef="T_NotifyApproved" />
    <bpmn:sequenceFlow id="f14b" sourceRef="T_NotifyApproved" targetRef="T_ConfirmAccount" />
    <bpmn:sequenceFlow id="f15" sourceRef="T_ConfirmAccount" targetRef="T_ProcessPayment" />
    <bpmn:sequenceFlow id="pe1" sourceRef="Bnd_PaymentError" targetRef="T_HandlePaymentFail" />
    <bpmn:sequenceFlow id="pe2" sourceRef="T_HandlePaymentFail" targetRef="T_ProcessPayment" />
    <bpmn:sequenceFlow id="f16" sourceRef="T_ProcessPayment" targetRef="T_Record" />
    <bpmn:sequenceFlow id="f17" sourceRef="T_Record" targetRef="T_ConfirmReceipt" />
    <bpmn:sequenceFlow id="f18" sourceRef="T_ConfirmReceipt" targetRef="T_NotifyDone" />
    <bpmn:sequenceFlow id="f19" sourceRef="T_NotifyDone" targetRef="End_Done" />
    <bpmn:sequenceFlow id="f20" sourceRef="T_NotifyReject" targetRef="End_Reject" />
    <bpmn:dataObjectReference id="DRB_Tiket" name="Tiket Refund" dataObjectRef="DOB_T