<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Refund_AS" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Refund_AS"><bpmn:participant id="Part_Refund_AS" name="Schoters by Ruangguru - Refund / Pembatalan (As-Is / Manual + Notifikasi Telegram)" processRef="Process_Refund_AS" /></bpmn:collaboration>
  <bpmn:process id="Process_Refund_AS" name="Refund / Pembatalan Program (As-Is)" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:laneSet id="LaneSet_Process_Refund_AS">
      <bpmn:lane id="L_Student" name="Mahasiswa"><bpmn:flowNodeRef>RAS_Start</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_AskMore</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_ConfirmAccount</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_EndReject</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_EndDone</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_CS" name="Customer Service"><bpmn:flowNodeRef>RAS_AutoAck</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_Receive</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_Verify</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_Doc</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_RequestDocs</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_CheckPolicy</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_RejectNotify</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_ResultNotify</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_Finance" name="Tim Finance"><bpmn:flowNodeRef>RAS_Calc</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_Discuss</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_Transfer</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_UpdateSheet</bpmn:flowNodeRef><bpmn:flowNodeRef>RAS_Reconcile</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="L_Manager" name="Manager"><bpmn:flowNodeRef>RAS_MgrReview</bpmn:flowNodeRef><bpmn:flowNodeRef>GW_Dec</bpmn:flowNodeRef></bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="RAS_Start" name="Mahasiswa Mengirim Permintaan Refund (Email/WA)" camunda:formRef="form_refund_request" camunda:formRefBinding="latest"><bpmn:outgoing>ra1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:serviceTask id="RAS_AutoAck" name="Kirim Konfirmasi Penerimaan Permintaan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCE5 [CS] Permintaan refund Anda telah kami terima dan sedang diproses secara manual oleh tim kami."}</camunda:inputParameter><camunda:outputParameter name="logAutoAck">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>ra1</bpmn:incoming><bpmn:outgoing>ra2</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="RAS_Receive" name="Terima &amp; Catat Permintaan"><bpmn:incoming>ra2</bpmn:incoming><bpmn:outgoing>ra3</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_catatan"><bpmn:targetRef>DR_Catatan</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="RAS_Verify" name="Verifikasi Kelengkapan Dokumen" camunda:formRef="form_doc_verify" camunda:formRefBinding="latest"><bpmn:incoming>ra3</bpmn:incoming><bpmn:incoming>ra_loop</bpmn:incoming><bpmn:outgoing>ra4</bpmn:outgoing><bpmn:property id="Prop_RAS_Verify_DR_Catatan" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Catatan_RAS_Verify"><bpmn:sourceRef>DR_Catatan</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_Verify_DR_Catatan</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Doc" name="Dokumen Lengkap?" default="ra7"><bpmn:incoming>ra4</bpmn:incoming><bpmn:outgoing>ra5</bpmn:outgoing><bpmn:outgoing>ra7</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="RAS_RequestDocs" name="Kirim Permintaan Dokumen Tambahan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\uD83D\uDCCE [CS] Dokumen Anda belum lengkap. Mohon kirimkan dokumen tambahan yang diminta."}</camunda:inputParameter><camunda:outputParameter name="logRequestDocs">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>ra5</bpmn:incoming><bpmn:outgoing>ra6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:userTask id="RAS_AskMore" name="Lengkapi Dokumen Tambahan"><bpmn:incoming>ra6</bpmn:incoming><bpmn:outgoing>ra_loop</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="RAS_CheckPolicy" name="Cek Kebijakan Refund Manual"><bpmn:incoming>ra7</bpmn:incoming><bpmn:outgoing>ra8</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_lembar"><bpmn:targetRef>DR_Lembar</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="RAS_Calc" name="Hitung Estimasi Nominal Refund"><bpmn:incoming>ra8</bpmn:incoming><bpmn:outgoing>ra9</bpmn:outgoing><bpmn:property id="Prop_RAS_Calc_DR_Lembar" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Lembar_RAS_Calc"><bpmn:sourceRef>DR_Lembar</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_Calc_DR_Lembar</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_hitung"><bpmn:targetRef>DR_Hitung</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="RAS_Discuss" name="Diskusi dgn Manager"><bpmn:incoming>ra9</bpmn:incoming><bpmn:outgoing>ra10</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="RAS_MgrReview" name="Tinjau &amp; Putuskan Refund" camunda:formRef="form_refund_review" camunda:formRefBinding="latest"><bpmn:incoming>ra10</bpmn:incoming><bpmn:outgoing>ra11</bpmn:outgoing><bpmn:property id="Prop_RAS_MgrReview_DR_Hitung" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Hitung_RAS_MgrReview"><bpmn:sourceRef>DR_Hitung</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_MgrReview_DR_Hitung</bpmn:targetRef></bpmn:dataInputAssociation></bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Dec" name="Keputusan Refund?" default="ra14"><bpmn:incoming>ra11</bpmn:incoming><bpmn:outgoing>ra12</bpmn:outgoing><bpmn:outgoing>ra14</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:serviceTask id="RAS_RejectNotify" name="Kirim Notifikasi Penolakan"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u274C [CS] Mohon maaf, permintaan refund Anda tidak dapat kami setujui sesuai kebijakan."}</camunda:inputParameter><camunda:outputParameter name="logRejectNotify">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>ra12</bpmn:incoming><bpmn:outgoing>ra13</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_emailtolak"><bpmn:targetRef>DR_EmailTolak</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:endEvent id="RAS_EndReject" name="Refund Ditolak"><bpmn:incoming>ra13</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="RAS_ConfirmAccount" name="Konfirmasi Rekening Tujuan Refund" camunda:formRef="form_account_confirm" camunda:formRefBinding="latest"><bpmn:incoming>ra14</bpmn:incoming><bpmn:outgoing>ra15</bpmn:outgoing><bpmn:dataOutputAssociation id="doa_rekening"><bpmn:targetRef>DR_Rekening</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="RAS_Transfer" name="Proses Transfer Bank Manual"><bpmn:incoming>ra15</bpmn:incoming><bpmn:outgoing>ra16</bpmn:outgoing><bpmn:property id="Prop_RAS_Transfer_DR_Rekening" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Rekening_RAS_Transfer"><bpmn:sourceRef>DR_Rekening</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_Transfer_DR_Rekening</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_bukti"><bpmn:targetRef>DR_Bukti</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="RAS_UpdateSheet" name="Update Status di Spreadsheet"><bpmn:incoming>ra16</bpmn:incoming><bpmn:outgoing>ra17</bpmn:outgoing><bpmn:property id="Prop_RAS_UpdateSheet_DR_Bukti" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Bukti_RAS_UpdateSheet"><bpmn:sourceRef>DR_Bukti</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_UpdateSheet_DR_Bukti</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_status"><bpmn:targetRef>DR_Status</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:userTask id="RAS_Reconcile" name="Rekonsiliasi Pembayaran"><bpmn:incoming>ra17</bpmn:incoming><bpmn:outgoing>ra18</bpmn:outgoing><bpmn:property id="Prop_RAS_Reconcile_DR_Status" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Status_RAS_Reconcile"><bpmn:sourceRef>DR_Status</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_Reconcile_DR_Status</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_rekon"><bpmn:targetRef>DR_Rekon</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:userTask>
    <bpmn:serviceTask id="RAS_ResultNotify" name="Kirim Notifikasi Hasil Refund"><bpmn:extensionElements><camunda:connector><camunda:connectorId>http-connector</camunda:connectorId><camunda:inputOutput><camunda:inputParameter name="url">https://api.telegram.org/bot8493118055:AAFusBcgndE72GV1RgXtaQkdFWGG0LDSAOo/sendMessage</camunda:inputParameter><camunda:inputParameter name="method">POST</camunda:inputParameter><camunda:inputParameter name="headers"><camunda:map><camunda:entry key="Content-Type">application/json</camunda:entry></camunda:map></camunda:inputParameter><camunda:inputParameter name="payload">{"chat_id":"8461739547","text":"\u2705 [CS] Refund Anda telah selesai diproses dan dana telah ditransfer. Terima kasih."}</camunda:inputParameter><camunda:outputParameter name="logResultNotify">${statusCode}</camunda:outputParameter></camunda:inputOutput></camunda:connector></bpmn:extensionElements><bpmn:incoming>ra18</bpmn:incoming><bpmn:outgoing>ra19</bpmn:outgoing><bpmn:property id="Prop_RAS_ResultNotify_DR_Rekon" name="__targetRef_placeholder" /><bpmn:dataInputAssociation id="DIn_DR_Rekon_RAS_ResultNotify"><bpmn:sourceRef>DR_Rekon</bpmn:sourceRef><bpmn:targetRef>Prop_RAS_ResultNotify_DR_Rekon</bpmn:targetRef></bpmn:dataInputAssociation><bpmn:dataOutputAssociation id="doa_konfirmasi"><bpmn:targetRef>DR_Konfirmasi</bpmn:targetRef></bpmn:dataOutputAssociation></bpmn:serviceTask>
    <bpmn:endEvent id="RAS_EndDone" name="Refund Selesai"><bpmn:incoming>ra19</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="ra1" sourceRef="RAS_Start" targetRef="RAS_AutoAck" />
    <bpmn:sequenceFlow id="ra2" sourceRef="RAS_AutoAck" targetRef="RAS_Receive" />
    <bpmn:sequenceFlow id="ra3" sourceRef="RAS_Receive" targetRef="RAS_Verify" />
    <bpmn:sequenceFlow id="ra4" sourceRef="RAS_Verify" targetRef="GW_Doc" />
    <bpmn:sequenceFlow id="ra5" sourceRef="GW_Doc" targetRef="RAS_RequestDocs" name="Belum Lengkap"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${dokumenLengkap == false}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ra6" sourceRef="RAS_RequestDocs" targetRef="RAS_AskMore" />
    <bpmn:sequenceFlow id="ra_loop" sourceRef="RAS_AskMore" targetRef="RAS_Verify" />
    <bpmn:sequenceFlow id="ra7" sourceRef="GW_Doc" targetRef="RAS_CheckPolicy" name="Lengkap" />
    <bpmn:sequenceFlow id="ra8" sourceRef="RAS_CheckPolicy" targetRef="RAS_Calc" />
    <bpmn:sequenceFlow id="ra9" sourceRef="RAS_Calc" targetRef="RAS_Discuss" />
    <bpmn:sequenceFlow id="ra10" sourceRef="RAS_Discuss" targetRef="RAS_MgrReview" />
    <bpmn:sequenceFlow id="ra11" sourceRef="RAS_MgrReview" targetRef="GW_Dec" />
    <bpmn:sequenceFlow id="ra12" sourceRef="GW_Dec" targetRef="RAS_RejectNotify" name="Ditolak"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reasonCategory == &quot;Invalid&quot;}</bpmn:conditionExpression></bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ra13" sourceRef="RAS_RejectNotify" targetRef="RAS_EndReject" />
    <bpmn:sequenceFlow id="ra14" sourceRef="GW_Dec" targetRef="RAS_ConfirmAccount" name="Disetujui" />
    <bpmn:sequenceFlow id="ra15" sourceRef="RAS_ConfirmAccount" targetRef="RAS_Transfer" />
    <bpmn:sequenceFlow id="ra16" sourceRef="RAS_Transfer" targetRef="RAS_UpdateSheet" />
    <bpmn:sequenceFlow id="ra17" sourceRef="RAS_UpdateSheet" targetRef="RAS_Reconcile" />
    <bpmn:sequenceFlow id="ra18" sourceRef="RAS_Reconcile" targetRef="RAS_ResultNotify" />
    <bpmn:sequenceFlow id="ra19" sourceRef="RAS_ResultNotify" targetRef="RAS_EndDone" />
    <bpmn:dataObjectReference id="DR_Catatan" name="Catatan Permintaan (Spreadsheet)" dataObjectRef="DO_Catatan" /><bpmn:dataObject id="DO_Catatan" />
    <bpmn:dataObjectReference id="DR_Lembar" name="Lembar Cek Kelayakan" dataObjectRef="DO_Lembar" /><bpmn:dataObject id="DO_Lembar" />
    <bpmn:dataObjectReference id="DR_Hitung" name="Perhitungan Refund (Excel)" dataObjectRef="DO_Hitung" /><bpmn:dataObject id="DO_Hitung" />
    <bpmn:dataObjectReference id="DR_Rekening" name="Data Rekening Tujuan" dataObjectRef="DO_Rekening" /><bpmn:dataObject id="DO_Rekening" />
    <bpmn:dataObjectReference id="DR_Bukti" name="Bukti Transfer Bank" dataObjectRef="DO_Bukti" /><bpmn:dataObject id="DO_Bukti" />
    <bpmn:dataObjectReference id="DR_Status" name="Status Spreadsheet" dataObjectRef="DO_Status" /><bpmn:dataObject id="DO_Status" />
    <bpmn:dataObjectReference id="DR_Rekon" name="Laporan Rekonsiliasi" dataObjectRef="DO_Rekon" /><bpmn:dataObject id="DO_Rekon" />
    <bpmn:dataObjectReference id="DR_EmailTolak" name="Notifikasi Penolakan (Telegram)" dataObjectRef="DO_EmailTolak" /><bpmn:dataObject id="DO_EmailTolak" />
    <bpmn:dataObjectReference id="DR_Konfirmasi" name="Notifikasi Konfirmasi Refund (Telegram)" dataObjectRef="DO_Konfirmasi" /><bpmn:dataObject id="DO_Konfirmasi" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_Process_Refund_AS">
    <bpmndi:BPMNPlane id="Plane_Process_Refund_AS" bpmnElement="Collab_Refund_AS">
      <bpmndi:BPMNShape id="di_Part_Refund_AS" bpmnElement="Part_Refund_AS" isHorizontal="true"><dc:Bounds x="160" y="80" width="3160" height="880" /></bpmndi:BPMNShape>
