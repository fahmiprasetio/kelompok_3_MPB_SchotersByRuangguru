<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Refund_AS" targetNamespace="http://bpmn.io/schema/bpmn" exporter="manual" exporterVersion="1.0">
  <bpmn:collaboration id="Collab_Refund_AS">
    <bpmn:participant id="Part_Refund_AS" name="Schoters by Ruangguru - Refund / Pembatalan (As-Is / Manual)" processRef="Process_Refund_AS" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Refund_AS" name="Refund / Pembatalan Program (As-Is)" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_Refund_AS">
      <bpmn:lane id="L_Student" name="Mahasiswa">
        <bpmn:flowNodeRef>RAS_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_AskMore</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_EndReject</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_EndDone</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_CS" name="Customer Service">
        <bpmn:flowNodeRef>RAS_Receive</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_Verify</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Doc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_CheckPolicy</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_RejectEmail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_Notify</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Finance" name="Tim Finance">
        <bpmn:flowNodeRef>RAS_Calc</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_Discuss</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_Transfer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>RAS_UpdateSheet</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="L_Manager" name="Manager">
        <bpmn:flowNodeRef>RAS_MgrReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_Dec</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="RAS_Start" name="Mahasiswa Mengirim Permintaan Refund (Email/WA)">
      <bpmn:outgoing>ra1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="RAS_Receive" name="Terima &amp; Catat Permintaan">
      <bpmn:incoming>ra1</bpmn:incoming>
      <bpmn:outgoing>ra2</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_catatan">
        <bpmn:targetRef>DR_Catatan</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_Verify" name="Verifikasi Kelengkapan Dokumen">
      <bpmn:incoming>ra2</bpmn:incoming>
      <bpmn:incoming>ra_loop</bpmn:incoming>
      <bpmn:outgoing>ra3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Doc" name="Dokumen Lengkap?" default="ra5">
      <bpmn:incoming>ra3</bpmn:incoming>
      <bpmn:outgoing>ra4</bpmn:outgoing>
      <bpmn:outgoing>ra5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="RAS_AskMore" name="Minta Dokumen Tambahan">
      <bpmn:incoming>ra4</bpmn:incoming>
      <bpmn:outgoing>ra_loop</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_CheckPolicy" name="Cek Kebijakan Refund Manual">
      <bpmn:incoming>ra5</bpmn:incoming>
      <bpmn:outgoing>ra6</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_lembar">
        <bpmn:targetRef>DR_Lembar</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_Calc" name="Hitung Estimasi Nominal Refund">
      <bpmn:incoming>ra6</bpmn:incoming>
      <bpmn:outgoing>ra7</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_hitung">
        <bpmn:targetRef>DR_Hitung</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_Discuss" name="Diskusi dgn Manager">
      <bpmn:incoming>ra7</bpmn:incoming>
      <bpmn:outgoing>ra8</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_MgrReview" name="Tinjau &amp; Putuskan Refund">
      <bpmn:incoming>ra8</bpmn:incoming>
      <bpmn:outgoing>ra9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_Dec" name="Keputusan?">
      <bpmn:incoming>ra9</bpmn:incoming>
      <bpmn:outgoing>ra10</bpmn:outgoing>
      <bpmn:outgoing>ra12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="RAS_RejectEmail" name="Kirim Email Penolakan">
      <bpmn:incoming>ra10</bpmn:incoming>
      <bpmn:outgoing>ra11</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_emailtolak">
        <bpmn:targetRef>DR_EmailTolak</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:endEvent id="RAS_EndReject" name="Refund Ditolak (Manual)">
      <bpmn:incoming>ra11</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="RAS_Transfer" name="Proses Transfer Bank Manual">
      <bpmn:incoming>ra12</bpmn:incoming>
      <bpmn:outgoing>ra13</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_bukti">
        <bpmn:targetRef>DR_Bukti</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_UpdateSheet" name="Update Status di Spreadsheet">
      <bpmn:incoming>ra13</bpmn:incoming>
      <bpmn:outgoing>ra14</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_status">
        <bpmn:targetRef>DR_Status</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="RAS_Notify" name="Kirim Notifikasi Hasil ke Mahasiswa">
      <bpmn:incoming>ra14</bpmn:incoming>
      <bpmn:outgoing>ra15</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="doa_konfirmasi">
        <bpmn:targetRef>DR_Konfirmasi</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:endEvent id="RAS_EndDone" name="Refund Selesai (Manual)">
      <bpmn:incoming>ra15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="ra1" sourceRef="RAS_Start" targetRef="RAS_Receive" />
    <bpmn:sequenceFlow id="ra2" sourceRef="RAS_Receive" targetRef="RAS_Verify" />
    <bpmn:sequenceFlow id="ra3" sourceRef="RAS_Verify" targetRef="GW_Doc" />
    <bpmn:sequenceFlow id="ra4" sourceRef="GW_Doc" targetRef="RAS_AskMore" name="Belum Lengkap">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ra_loop" sourceRef="RAS_AskMore" targetRef="RAS_Verify" />
    <bpmn:sequenceFlow id="ra5" sourceRef="GW_Doc" targetRef="RAS_CheckPolicy" name="Lengkap">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ra6" sourceRef="RAS_CheckPolicy" targetRef="RAS_Calc" />
    <bpmn:sequenceFlow id="ra7" sourceRef="RAS_Calc" targetRef="RAS_Discuss" />
    <bpmn:sequenceFlow id="ra8" sourceRef="RAS_Discuss" targetRef="RAS_MgrReview" />
    <bpmn:sequenceFlow id="ra9" sourceRef="RAS_MgrReview" targetRef="GW_Dec" />
    <bpmn:sequenceFlow id="ra10" sourceRef="GW_Dec" targetRef="RAS_RejectEmail" name="Ditolak">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ra11" sourceRef="RAS_RejectEmail" targetRef="RAS_EndReject" />
    <bpmn:sequenceFlow id="ra12" sourceRef="GW_Dec" targetRef="RAS_Transfer" name="Disetujui">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="ra13" sourceRef="RAS_Transfer" targetRef="RAS_UpdateSheet" />
    <bpmn:sequenceFlow id="ra14" sourceRef="RAS_UpdateSheet" targetRef="RAS_Notify" />
    <bpmn:sequenceFlow id="ra15" sourceRef="RAS_Notify" targetRef="RAS_EndDone" />
    <bpmn:dataObjectReference id="DR_Catatan" name="Catatan Permintaan (Spreadsheet)" dataObjectRef="DO_Catatan" />
    <bpmn:dataObject id="DO_Catatan" />
    <bpmn:dataObjectReference id="DR_Lembar" name="Lembar Cek Kelayakan" dataObjectRef="DO_Lembar" />
    <bpmn:dataObject id="DO_Lembar" />
    <bpmn:dataObjectReference id="DR_Hitung" name="Perhitungan Refund (Excel)" dataObjectRef="DO_Hitung" />
    <bpmn:dataObject id="DO_Hitung" />
    <bpmn:dataObjectReference id="DR_EmailTolak" name="Email Penolakan" dataObjectRef="DO_EmailTolak" />
    <bpmn:dataObject id="DO_EmailTolak" />
    <bpmn:dataObjectReference id="DR_Bukti" name="Bukti Transfer Bank" dataObjectRef="DO_Bukti" />
    <bpmn:dataObject id="DO_Bukti" />
    <bpmn:dataObjectReference id="DR_Status" name="Status Spreadsheet" dataObjectRef="DO_Status" />
    <bpmn:dataObject id="DO_Status" />
    <bpmn:dataObjectReference id="DR_Konfirmasi" name="Email Konfirmasi Refund" dataObjectRef="DO_Konfirmasi" />
    <bpmn:dataObject id="DO_Konfirmasi" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diag_Process_Refund_AS">
    <bpmndi:BPMNPlane id="Plane_Process_Refund_AS" bpmnElement="Collab_Refund_AS">
      <bpmndi:BPMNShape id="di_Part_Refund_AS" bpmnElement="Part_Refund_AS" isHorizontal="true"><dc:Bounds x="160" y="80" width="2816" height="880" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Student" bpmnElement="L_Student" isHorizontal="true"><dc:Bounds x="190" y="80" width="2786" height="220" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_CS" bpmnElement="L_CS" isHorizontal="true"><dc:Bounds x="190" y="300" width="2786" height="220" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Finance" bpmnElement="L_Finance" isHorizontal="true"><dc:Bounds x="190" y="520" width="2786" height="220" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_L_Manager" bpmnElement="L_Manager" isHorizontal="true"><dc:Bounds x="190" y="740" width="2786" height="220" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Start" bpmnElement="RAS_Start"><dc:Bounds x="260" y="172" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Receive" bpmnElement="RAS_Receive"><dc:Bounds x="420" y="370" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Verify" bpmnElement="RAS_Verify"><dc:Bounds x="620" y="370" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Doc" bpmnElement="GW_Doc"><dc:Bounds x="860" y="385" width="50" height="50" /></bpmndi:BPMNShape>
