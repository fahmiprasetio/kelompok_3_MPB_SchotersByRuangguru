      <bpmndi:BPMNShape id="di_RAS_Calc" bpmnElement="RAS_Calc"><dc:Bounds x="1420" y="590" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Discuss" bpmnElement="RAS_Discuss"><dc:Bounds x="1620" y="590" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_MgrReview" bpmnElement="RAS_MgrReview"><dc:Bounds x="1820" y="810" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_GW_Dec" bpmnElement="GW_Dec"><dc:Bounds x="2060" y="825" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_RejectEmail" bpmnElement="RAS_RejectEmail"><dc:Bounds x="2240" y="370" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_EndReject" bpmnElement="RAS_EndReject"><dc:Bounds x="2460" y="172" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Transfer" bpmnElement="RAS_Transfer"><dc:Bounds x="2240" y="590" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_UpdateSheet" bpmnElement="RAS_UpdateSheet"><dc:Bounds x="2440" y="590" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_Notify" bpmnElement="RAS_Notify"><dc:Bounds x="2640" y="370" width="120" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_RAS_EndDone" bpmnElement="RAS_EndDone"><dc:Bounds x="2860" y="172" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_Catatan" bpmnElement="DR_Catatan"><dc:Bounds x="462" y="308" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_Lembar" bpmnElement="DR_Lembar"><dc:Bounds x="1262" y="308" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_Hitung" bpmnElement="DR_Hitung"><dc:Bounds x="1462" y="528" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_EmailTolak" bpmnElement="DR_EmailTolak"><dc:Bounds x="2282" y="308" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_Bukti" bpmnElement="DR_Bukti"><dc:Bounds x="2282" y="528" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_Status" bpmnElement="DR_Status"><dc:Bounds x="2482" y="528" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="di_DR_Konfirmasi" bpmnElement="DR_Konfirmasi"><dc:Bounds x="2682" y="308" width="36" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="di_ra1" bpmnElement="ra1"><di:waypoint x="296" y="190" /><di:waypoint x="358" y="190" /><di:waypoint x="358" y="410" /><di:waypoint x="420" y="410" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra2" bpmnElement="ra2"><di:waypoint x="540" y="410" /><di:waypoint x="620" y="410" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra3" bpmnElement="ra3"><di:waypoint x="740" y="410" /><di:waypoint x="860" y="410" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra4" bpmnElement="ra4"><di:waypoint x="910" y="410" /><di:waypoint x="965" y="410" /><di:waypoint x="965" y="190" /><di:waypoint x="1020" y="190" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra_loop" bpmnElement="ra_loop"><di:waypoint x="1080" y="230" /><di:waypoint x="1080" y="490" /><di:waypoint x="680" y="490" /><di:waypoint x="680" y="450" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra5" bpmnElement="ra5"><di:waypoint x="910" y="410" /><di:waypoint x="1220" y="410" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra6" bpmnElement="ra6"><di:waypoint x="1340" y="410" /><di:waypoint x="1380" y="410" /><di:waypoint x="1380" y="630" /><di:waypoint x="1420" y="630" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra7" bpmnElement="ra7"><di:waypoint x="1540" y="630" /><di:waypoint x="1620" y="630" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra8" bpmnElement="ra8"><di:waypoint x="1740" y="630" /><di:waypoint x="1780" y="630" /><di:waypoint x="1780" y="850" /><di:waypoint x="1820" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra9" bpmnElement="ra9"><di:waypoint x="1940" y="850" /><di:waypoint x="2060" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra10" bpmnElement="ra10"><di:waypoint x="2110" y="850" /><di:waypoint x="2175" y="850" /><di:waypoint x="2175" y="410" /><di:waypoint x="2240" y="410" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra11" bpmnElement="ra11"><di:waypoint x="2360" y="410" /><di:waypoint x="2410" y="410" /><di:waypoint x="2410" y="190" /><di:waypoint x="2460" y="190" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra12" bpmnElement="ra12"><di:waypoint x="2110" y="850" /><di:waypoint x="2175" y="850" /><di:waypoint x="2175" y="630" /><di:waypoint x="2240" y="630" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra13" bpmnElement="ra13"><di:waypoint x="2360" y="630" /><di:waypoint x="2440" y="630" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_ra14" bpmnElement="ra14"><di:waypoint x="2560" y="630" /><di:waypoint x="2600" y="630" /><di:waypoint x="2600" y="410" /><di:waypoint x="2640" y="410" /></bpmndi:BPMNEdge>
