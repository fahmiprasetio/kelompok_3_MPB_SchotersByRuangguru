      <bpmndi:BPMNEdge id="di_doa_bukti" bpmnElement="doa_bukti"><di:waypoint x="2300" y="590" /><di:waypoint x="2300" y="578" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_doa_status" bpmnElement="doa_status"><di:waypoint x="2500" y="590" /><di:waypoint x="2500" y="578" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_doa_konfirmasi" bpmnElement="doa_konfirmasi"><di:waypoint x="2700" y="370" /><di:waypoint x="2700" y="358" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
