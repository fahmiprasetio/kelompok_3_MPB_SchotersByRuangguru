      <bpmndi:BPMNEdge id="di_doa_catatan" bpmnElement="doa_catatan"><di:waypoint x="480" y="370" /><di:waypoint x="480" y="358" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_doa_lembar" bpmnElement="doa_lembar"><di:waypoint x="1280" y="370" /><di:waypoint x="1280" y="358" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="di_doa_hitung" bpmnElement="doa_hitung"><di:waypoint x="1480" y="590" /><di:waypoint x="1480" y="578" /></bpmndi:BPMNEdge>
